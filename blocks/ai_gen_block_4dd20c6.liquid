{% doc %}
  @prompt
    an about section to talk about the artist, we do not want an artist image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-artist-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-about-artist-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-about-artist-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    align-items: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .ai-about-artist-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-family: var(--font-heading-family);
    line-height: 1.2;
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-about-artist-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.line_height }};
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-about-artist-text-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-about-artist-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-about-artist-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: 16px;
    transition: all 0.3s ease;
    cursor: pointer;
    width: fit-content;
  }

  .ai-about-artist-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-about-artist-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 20px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-about-artist-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-about-artist-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<artist-about-{{ ai_gen_id }} class="ai-about-artist-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-artist-container-{{ ai_gen_id }}">
    <div class="ai-about-artist-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-about-artist-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.artist_bio != blank %}
        <div class="ai-about-artist-text-{{ ai_gen_id }}">
          {{ block.settings.artist_bio }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-about-artist-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</artist-about-{{ ai_gen_id }}>

<script>
  (function() {
    class ArtistAbout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('artist-about-{{ ai_gen_id }}', ArtistAbout{{ ai_gen_id }});
  })();
</script>

