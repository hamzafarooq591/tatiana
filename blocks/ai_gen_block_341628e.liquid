{% doc %}
  @prompt
    a three block section that show signed and sealed authenticity 
    
    two year finish commitment 
    
    handled and insured delivery 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-trust-badges__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-trust-badges__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-trust-badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.badge_padding }}px;
    background-color: {{ block.settings.badge_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-trust-badge__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-badge__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-trust-badge__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-trust-badge__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-trust-badge__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-trust-badge__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-badge__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-trust-badge__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<trust-badges-{{ ai_gen_id }} class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges__container-{{ ai_gen_id }}">
    <div class="ai-trust-badges__grid-{{ ai_gen_id }}">
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
        </div>
        <div class="ai-trust-badge__content-{{ ai_gen_id }}">
          <h3 class="ai-trust-badge__title-{{ ai_gen_id }}">{{ block.settings.badge_1_title }}</h3>
          {% if block.settings.badge_1_description != blank %}
            <p class="ai-trust-badge__description-{{ ai_gen_id }}">{{ block.settings.badge_1_description }}</p>
          {% endif %}
        </div>
      </div>

      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="ai-trust-badge__content-{{ ai_gen_id }}">
          <h3 class="ai-trust-badge__title-{{ ai_gen_id }}">{{ block.settings.badge_2_title }}</h3>
          {% if block.settings.badge_2_description != blank %}
            <p class="ai-trust-badge__description-{{ ai_gen_id }}">{{ block.settings.badge_2_description }}</p>
          {% endif %}
        </div>
      </div>

      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"/>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
        </div>
        <div class="ai-trust-badge__content-{{ ai_gen_id }}">
          <h3 class="ai-trust-badge__title-{{ ai_gen_id }}">{{ block.settings.badge_3_title }}</h3>
          {% if block.settings.badge_3_description != blank %}
            <p class="ai-trust-badge__description-{{ ai_gen_id }}">{{ block.settings.badge_3_description }}</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</trust-badges-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Trust badges",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "text",
      "id": "badge_1_title",
      "label": "Title",
      "default": "Signed & Sealed Authenticity"
    },
    {
      "type": "text",
      "id": "badge_1_description",
      "label": "Description",
      "default": "Every piece comes with a certificate of authenticity"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "text",
      "id": "badge_2_title",
      "label": "Title",
      "default": "Two Year Finish Commitment"
    },
    {
      "type": "text",
      "id": "badge_2_description",
      "label": "Description",
      "default": "We guarantee the quality of our finish for 2 years"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "text",
      "id": "badge_3_title",
      "label": "Title",
      "default": "Handled & Insured Delivery"
    },
    {
      "type": "text",
      "id": "badge_3_description",
      "label": "Description",
      "default": "White glove delivery service with full insurance"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space between badges",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "badge_padding",
      "label": "Badge padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Icon to text spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Badge border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#5d2b09"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Badge background",
      "default": "#f7f1ed"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#170b02"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#170b02"
    }
  ],
  "presets": [
    {
      "name": "Trust badges"
    }
  ]
}
{% endschema %}
