{%- comment -%}
  ============================================================
  TatianaGlen — Custom Product Page
  File: sections/main-product-custom.liquid
  ============================================================
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_media   = current_variant.featured_media | default: product.featured_media
-%}

{% style %}
/* ============================================================
   BRAND VARIABLES
   ============================================================ */
#shopify-section-{{ section.id }} {
  --tgp-gold:    #cd8f5c;
  --tgp-dark:    #1a1a1a;
  --tgp-text:    #1a1a1a;
  --tgp-muted:   #6b7280;
  --tgp-border:  #e5e5e5;
  --tgp-bg-warm: #f9f5f0;
  --tgp-serif:   'Playfair Display', Georgia, serif;
  --tgp-sans:    'Montserrat', Arial, sans-serif;
  background: #ffffff;
  font-family: var(--tgp-sans);
}

/* Override theme heading letter-spacing/weight inside this section */
#shopify-section-{{ section.id }} h1,
#shopify-section-{{ section.id }} h2,
#shopify-section-{{ section.id }} h3,
#shopify-section-{{ section.id }} h4 {
  letter-spacing: 0.05em !important;
  font-weight: 400 !important;
  text-transform: none;
}
/* But keep product title bold */
#shopify-section-{{ section.id }} .tgp-info__title {
  letter-spacing: -0.01em !important;
  font-weight: 700 !important;
}

/* ============================================================
   MAIN PRODUCT — 2-column grid
   ============================================================ */
.tgp-product {
  max-width: 1440px;
  margin: 0 auto;
  padding: 40px 80px 60px;
  display: grid;
  grid-template-columns: 50% 50%;
  align-items: flex-start;
}

/* ============================================================
   GALLERY — main image on top, thumbs below
   ============================================================ */
.tgp-gallery {
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: sticky;
  top: 24px;
}

/* Main image container */
.tgp-gallery__main {
  position: relative;
  overflow: hidden;
  background: #f0f0f0;
}
.tgp-gallery__main-img {
  width: 100%;
  display: block;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  transition: opacity 0.3s ease;
}
/* Panning zoom image injected by JS */
.tgp-zoom-img {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
  pointer-events: none;
  max-width: none;
  max-height: none;
  border: none;
  display: block;
  transition: opacity 0.12s ease;
}
.tgp-gallery__main { cursor: crosshair; }

/* Zoom icon button */
.tgp-gallery__zoom {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 36px;
  height: 36px;
  background: var(--tgp-gold);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
  z-index: 2;
}
.tgp-gallery__zoom:hover { background: #b8923e; }
.tgp-gallery__zoom svg {
  width: 15px; height: 15px;
  stroke: #fff;
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* Horizontal thumbnail strip */
.tgp-gallery__thumbs {
  display: flex;
  flex-direction: row;
  gap: 8px;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 2px;
}
.tgp-gallery__thumbs::-webkit-scrollbar { display: none; }

.tgp-gallery__thumb {
  width: 68px;
  height: 68px;
  object-fit: cover;
  cursor: pointer;
  border: 2px solid transparent;
  flex-shrink: 0;
  display: block;
  opacity: 0.65;
  transition: border-color 0.2s ease, opacity 0.2s ease;
}
.tgp-gallery__thumb.is-active,
.tgp-gallery__thumb:hover {
  border-color: var(--tgp-gold);
  opacity: 1;
}

/* ============================================================
   PRODUCT INFO — right column
   ============================================================ */
.tgp-info { padding: 0px 40px; }

/* Title row — title left, brand right */
.tgp-info__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 16px;
}
.tgp-info__title {
  font-family: 'Montserrat', sans-serif;
  font-size: 38px;
  font-weight: 700 !important;
  line-height: 1.18;
  color: var(--tgp-text);
  margin: 0;
  letter-spacing: -0.01em;
  flex: 1;
  text-transform: none !important;
}
.tgp-info__brand {
  font-family: var(--tgp-sans);
  font-size: 12px;
  font-weight: 400;
  color: var(--tgp-gold);
  white-space: nowrap;
  padding-top: 8px;
  letter-spacing: 0.02em;
}

/* Price */
.tgp-info__price-wrap {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 20px;
}
.tgp-info__price {
  font-family: var(--tgp-sans);
  font-size: 26px;
  font-weight: 600;
  color: var(--tgp-gold);
  letter-spacing: 0.02em;
}
.tgp-info__price-compare {
  font-family: var(--tgp-sans);
  font-size: 16px;
  font-weight: 300;
  color: var(--tgp-muted);
  text-decoration: line-through;
}

/* Short description */
.tgp-info__short-desc {
  font-family: 'Montserrat';
  font-size: 14px;
  font-weight: 400;
  color: var(--tgp-muted);
  line-height: 1.8;
  margin: 0 0 24px;
}
.tgp-info__short-desc p { margin-bottom: 10px; }
.tgp-info__short-desc p:last-child { margin-bottom: 0; }

/* Divider */
.tgp-info__divider {
  border: none;
  border-top: 1px solid var(--tgp-border);
  margin: 20px 0;
}

/* Variant options */
.tgp-variants { margin-bottom: 10px; }
.tgp-variants__label {
  font-family: var(--tgp-sans);
  font-size: 14px;
  font-weight: 400;
  color: var(--tgp-text);
  display: block;
  margin-bottom: 10px;
  letter-spacing: 0.01em;
}
.tgp-variants__label strong {
  font-weight: 700;
}
.tgp-variants__options {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.tgp-variant-btn {
  padding: 8px 20px;
  border: 1px solid #ccc;
  background: #fff;
  font-family: var(--tgp-sans);
  font-size: 14px;
  font-weight: 400;
  color: var(--tgp-text);
  cursor: pointer;
  transition: border-color 0.2s ease;
  border-radius: 0;
}
.tgp-variant-btn.is-selected {
  border: 1px solid var(--tgp-gold);
  color: var(--tgp-gold);
  font-weight: 600;
}
.tgp-variant-btn:hover:not(.is-selected) { border-color: #888; }
.tgp-variant-btn.is-unavailable {
  opacity: 0.35;
  cursor: not-allowed;
  text-decoration: line-through;
}
/* Clear link */
.tgp-variants__clear {
  display: inline-block;
  margin-top: 6px;
  margin-bottom: 4px;
  font-family: var(--tgp-sans);
  font-size: 12px;
  color: var(--tgp-gold);
  text-decoration: underline;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
}

/* Quantity + ATC — side by side */
.tgp-buy-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}
.tgp-quantity {
  display: flex;
  align-items: center;
  border: 2px solid var(--tgp-border);
  width: 120px;
  flex-shrink: 0;
}
.tgp-quantity__btn {
  width: 40px;
  height: 50px;
  background: transparent;
  border: none;
  font-size: 14px;
  font-weight: 400;
  color: var(--tgp-text);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  user-select: none;
  flex-shrink: 0;
}
.tgp-quantity__btn:hover { color: var(--tgp-gold); }
.tgp-quantity__input {
  width: 33.33%;
  flex: 1;
  height: 50px;
  text-align: center;
  border: none;
  border-left: 1px solid var(--tgp-border);
  border-right: 1px solid var(--tgp-border);
  font-family: var(--tgp-sans);
  font-size: 16px;
  font-weight: 400;
  color: var(--tgp-text);
  background: transparent;
  outline: none;
  padding: 14px 0;
  -moz-appearance: textfield;
}
.tgp-quantity__input::-webkit-outer-spin-button,
.tgp-quantity__input::-webkit-inner-spin-button { -webkit-appearance: none; }

/* Add to Cart */
.tgp-atc {
  min-width: 160px;
  padding: 16px 42px;
  background: #1a1a1a;
  color: #ffffff;
  border: none;
  font-family: var(--tgp-sans);
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-transform: capitalize;
  cursor: pointer;
  transition: background 0.3s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}
.tgp-atc:hover:not(:disabled) { background: #333333; }
.tgp-atc:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

/* Compare / Wishlist links */
.tgp-product-actions {
  display: flex;
  gap: 24px;
  margin-bottom: 18px;
}
.tgp-product-actions a {
  font-family: var(--tgp-sans);
  font-size: 12px;
  color: var(--tgp-muted);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: color 0.2s ease;
}
.tgp-product-actions a:hover { color: var(--tgp-dark); }
.tgp-product-actions svg {
  width: 14px; height: 14px;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* Dynamic payment buttons */
.tgp-payment-btns { margin-bottom: 16px; }
.tgp-payment-btns .shopify-payment-button__button { border-radius: 0 !important; }

/* SKU / Category / Brand meta */
.tgp-meta {
  border-top: 1px solid var(--tgp-border);
  padding-top: 14px;
  margin-top: 6px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.tgp-meta__item {
  font-family: var(--tgp-sans);
  font-size: 13px;
  color: var(--tgp-muted);
}
.tgp-meta__item strong {
  color: var(--tgp-dark);
  font-weight: 600;
}

/* ============================================================
   HORIZONTAL TABS
   ============================================================ */
.tgp-tabs {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 80px 60px;
}
.tgp-tabs__nav {
  display: flex;
  border-bottom: 1px solid var(--tgp-border);
  margin-bottom: 0;
}
.tgp-tab-btn {
  padding: 14px 24px 12px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  font-family: var(--tgp-sans);
  font-size: 14px;
  font-weight: 400;
  color: var(--tgp-muted);
  cursor: pointer;
  letter-spacing: 0.01em;
  transition: color 0.2s ease, border-color 0.2s ease;
  white-space: nowrap;
}
.tgp-tab-btn.is-active {
  color: var(--tgp-dark);
  font-weight: 700;
  border-bottom-color: var(--tgp-dark);
}
.tgp-tab-btn:hover:not(.is-active) { color: var(--tgp-dark); }

.tgp-tab-panel {
  display: none;
  padding: 32px 0 0;
  font-family: var(--tgp-sans);
  font-size: 13px;
  color: var(--tgp-muted);
  line-height: 1.9;
}
.tgp-tab-panel.is-active { display: block; }

.tgp-tab-panel p { margin-bottom: 12px; }
.tgp-tab-panel ul, .tgp-tab-panel ol { padding-left: 18px; margin-bottom: 12px; }
.tgp-tab-panel li { margin-bottom: 6px; }
.tgp-tab-panel h1, .tgp-tab-panel h2,
.tgp-tab-panel h3, .tgp-tab-panel h4 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 400;
  color: var(--tgp-dark);
  margin-bottom: 10px;
}

/* Attributes table inside Additional Info tab */
.tgp-attrs {
  width: 100%;
  border-collapse: collapse;
}
.tgp-attrs tr:nth-child(odd) { background: #f7f5f2; }
.tgp-attrs tr:nth-child(even) { background: #ffffff; }
.tgp-attrs td {
  padding: 12px 16px;
  font-size: 13px;
  line-height: 1.6;
  border-bottom: 1px solid var(--tgp-border);
  vertical-align: top;
}
.tgp-attrs td:first-child {
  font-weight: 600;
  color: var(--tgp-dark);
  width: 38%;
  white-space: nowrap;
}
.tgp-attrs td:last-child { color: var(--tgp-muted); }

/* Reviews placeholder */
.tgp-reviews-placeholder {
  color: var(--tgp-muted);
  font-size: 13px;
  padding: 20px 0;
}

/* ============================================================
   RELATED PRODUCTS
   ============================================================ */
.tgp-related {
  max-width: 1440px;
  margin: 0 auto;
  padding: 60px 80px;
  border-top: 1px solid var(--tgp-border);
}
.tgp-related__heading {
  font-family: var(--tgp-sans);
  font-size: 22px;
  font-weight: 400;
  color: var(--tgp-dark);
  text-align: center;
  margin: 0 0 40px;
  letter-spacing: 0.01em;
}
.tgp-related__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.tgp-related-card {
  text-decoration: none;
  color: inherit;
  display: block;
}
.tgp-related-card__img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  background: #f5f5f5;
  margin-bottom: 12px;
}
.tgp-related-card__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}
.tgp-related-card:hover .tgp-related-card__img { transform: scale(1.04); }
.tgp-related-card__title {
  font-family: var(--tgp-sans);
  font-size: 14px;
  font-weight: 400;
  color: var(--tgp-text);
  margin: 0 0 6px;
  line-height: 1.4;
}
.tgp-related-card__price {
  font-family: var(--tgp-sans);
  font-size: 13px;
  font-weight: 600;
  color: var(--tgp-text);
}

/* ============================================================
   TRUST BADGES — warm bg, icon left + text right
   ============================================================ */
.tgp-trust {
  background: #f5ede4;
  padding: 48px 80px;
}
.tgp-trust__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 48px;
}
.tgp-trust__item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16px;
}
.tgp-trust__icon {
  flex-shrink: 0;
}
.tgp-trust__icon svg {
  width: 40px;
  height: 40px;
  stroke: var(--tgp-dark);
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.tgp-trust__body { display: flex; flex-direction: column; gap: 6px; }
.tgp-trust__title {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--tgp-dark);
  margin: 0;
  letter-spacing: 0.01em;
}
.tgp-trust__text {
  font-family: var(--tgp-sans);
  font-size: 13px;
  font-weight: 400;
  color: var(--tgp-muted);
  line-height: 1.7;
  margin: 0;
}

/* ============================================================
   LIGHTBOX MODAL
   ============================================================ */
.tgp-lightbox {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.96);
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.tgp-lightbox.is-open { display: flex; }

/* Toolbar top */
.tgp-lightbox__toolbar {
  position: absolute;
  top: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  z-index: 2;
}
.tgp-lightbox__counter {
  color: rgba(255,255,255,0.85);
  font-family: var(--tgp-sans);
  font-size: 14px;
  font-weight: 400;
}
.tgp-lightbox__actions {
  display: flex;
  gap: 4px;
}
.tgp-lightbox__action-btn {
  width: 40px; height: 40px;
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.75);
  border-radius: 4px;
  transition: color 0.2s, background 0.2s;
}
.tgp-lightbox__action-btn:hover { color: #fff; background: rgba(255,255,255,0.1); }
.tgp-lightbox__action-btn svg {
  width: 18px; height: 18px;
  stroke: currentColor; fill: none;
  stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
}

/* Stage */
.tgp-lightbox__stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 72px 80px 60px;
  box-sizing: border-box;
}
.tgp-lightbox__img {
  max-width: 100%;
  max-height: calc(100vh - 140px);
  object-fit: contain;
  display: block;
  user-select: none;
}
.tgp-lightbox__caption {
  color: rgba(255,255,255,0.6);
  font-family: var(--tgp-sans);
  font-size: 13px;
  margin-top: 14px;
  text-align: center;
}

/* Prev / Next arrows */
.tgp-lightbox__prev,
.tgp-lightbox__next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 52px; height: 80px;
  background: rgba(255,255,255,0.06);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.8);
  transition: background 0.2s, color 0.2s;
  z-index: 2;
}
.tgp-lightbox__prev { left: 0; }
.tgp-lightbox__next { right: 0; }
.tgp-lightbox__prev:hover,
.tgp-lightbox__next:hover { background: rgba(255,255,255,0.12); color: #fff; }
.tgp-lightbox__prev svg,
.tgp-lightbox__next svg {
  width: 20px; height: 20px;
  stroke: currentColor; fill: none;
  stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
}

/* ============================================================
   FADE-IN
   ============================================================ */
.tgp-fade-in {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.tgp-fade-in.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================================
   RESPONSIVE — Tablet ≤1024px
   ============================================================ */
@media screen and (max-width: 1024px) {
  .tgp-product  { padding: 36px 40px 48px; gap: 40px; }
  .tgp-tabs     { padding: 0 40px 48px; }
  .tgp-related  { padding: 48px 40px; }
  .tgp-trust    { padding: 48px 40px; }
  .tgp-related__grid { grid-template-columns: repeat(2, 1fr); }
}

/* ============================================================
   RESPONSIVE — Mobile ≤767px
   ============================================================ */
@media screen and (max-width: 767px) {
  .tgp-product {
    grid-template-columns: 1fr;
    padding: 20px 20px 36px;
    gap: 24px;
    position: static;
  }
  .tgp-gallery { position: static; }
  .tgp-info__title { font-size: 24px; }
  .tgp-tabs { padding: 0 20px 40px; }
  .tgp-tabs__nav { overflow-x: auto; }
  .tgp-tab-btn { padding: 12px 16px 10px; font-size: 13px; }
  .tgp-related { padding: 40px 20px; }
  .tgp-related__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .tgp-trust { padding: 40px 20px; }
  .tgp-trust__inner { grid-template-columns: 1fr; gap: 32px; }
}
{% endstyle %}

{%- comment -%} ====================================================
    SECTION HTML
    ==================================================== {%- endcomment -%}
<div id="tgp-{{ section.id }}" class="tgp-product-page" data-tgp-root data-section-id="{{ section.id }}">

  {%- comment -%} ──────────── MAIN PRODUCT ──────────── {%- endcomment -%}
  <section class="tgp-product tgp-fade-in" data-tgp-product>

    {%- comment -%} ── LEFT: GALLERY ── {%- endcomment -%}
    <div class="tgp-gallery" data-tgp-gallery>

      {%- comment -%} Main large image {%- endcomment -%}
      <div class="tgp-gallery__main" data-tgp-gallery-main>
        <img
          src="{{ featured_media | image_url: width: 1200 }}"
          data-large-src="{{ featured_media | image_url: width: 2400 }}"
          alt="{{ featured_media.alt | escape | default: product.title }}"
          class="tgp-gallery__main-img"
          data-tgp-main-img
          loading="eager"
          width="{{ featured_media.width }}"
          height="{{ featured_media.height }}"
        >
        <button class="tgp-gallery__zoom" aria-label="Zoom image" type="button">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
            <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
          </svg>
        </button>
      </div>

      {%- comment -%} Horizontal thumbnail strip {%- endcomment -%}
      <div class="tgp-gallery__thumbs" data-tgp-thumbs>
        {%- for image in product.images -%}
          <img
            src="{{ image | image_url: width: 160 }}"
            data-src="{{ image | image_url: width: 1200 }}"
            data-large-src="{{ image | image_url: width: 2400 }}"
            alt="{{ image.alt | escape | default: product.title }}"
            class="tgp-gallery__thumb{% if forloop.first %} is-active{% endif %}"
            data-tgp-thumb="{{ forloop.index0 }}"
            loading="lazy"
            width="68"
            height="68"
          >
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} ── RIGHT: PRODUCT INFO ── {%- endcomment -%}
    <div class="tgp-info" data-tgp-info>

      {%- comment -%} Title + brand side by side {%- endcomment -%}
      <div class="tgp-info__header">
        <h1 class="tgp-info__title">{{ product.title }}</h1>
        <span class="tgp-info__brand">Tatiana &amp; Glen</span>
      </div>

      {%- comment -%} Price {%- endcomment -%}
      <div class="tgp-info__price-wrap">
        <span class="tgp-info__price" data-tgp-price-amount>
          {{ current_variant.price | money }}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="tgp-info__price-compare" data-tgp-compare-price>
            {{ current_variant.compare_at_price | money }}
          </span>
        {%- endif -%}
      </div>

      <hr class="tgp-info__divider">

      {%- comment -%} Short description {%- endcomment -%}
      {%- if product.metafields.custom.short_description != blank -%}
        <div class="tgp-info__short-desc rte">{{ product.metafields.custom.short_description }}</div>
      {%- elsif product.description != blank -%}
        <div class="tgp-info__short-desc rte">{{ product.description }}</div>
      {%- endif -%}

      {%- comment -%} Variant options {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        <div class="tgp-variants" data-tgp-variants>
          {%- for option in product.options_with_values -%}
            <span class="tgp-variants__label">
              {{ option.name }} : <strong data-tgp-option-selected="{{ option.position }}">{{ option.selected_value }}</strong>
            </span>
            <div class="tgp-variants__options">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="tgp-variant-btn{% if option.selected_value == value %} is-selected{% endif %}"
                  data-tgp-option="{{ option.position }}"
                  data-tgp-value="{{ value | escape }}"
                  aria-label="{{ option.name }}: {{ value }}"
                >{{ value }}</button>
              {%- endfor -%}
            </div>
            <button type="button" class="tgp-variants__clear" data-tgp-clear="{{ option.position }}">Clear</button>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- comment -%} Quantity + ATC row {%- endcomment -%}
      {%- form 'product', product, id: 'tgp-product-form', data-tgp-form: '' -%}
        <input type="hidden" name="id"       value="{{ current_variant.id }}" data-tgp-variant-id>
        <input type="hidden" name="quantity" value="1"                        data-tgp-qty-hidden>

        <div class="tgp-buy-row">
          <div class="tgp-quantity">
            <button class="tgp-quantity__btn" type="button" data-tgp-qty-minus aria-label="Decrease">&#8722;</button>
            <input
              class="tgp-quantity__input"
              type="number"
              name="quantity"
              value="1"
              min="1"
              aria-label="Quantity"
              data-tgp-qty-input
            >
            <button class="tgp-quantity__btn" type="button" data-tgp-qty-plus aria-label="Increase">&#43;</button>
          </div>

          <button
            class="tgp-atc"
            type="submit"
            name="add"
            data-tgp-atc
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}Add To Cart{%- else -%}Sold Out{%- endif -%}
          </button>
        </div>

        <div class="tgp-payment-btns">{{ form | payment_button }}</div>
      {%- endform -%}

      {%- comment -%} Compare + Wishlist links {%- endcomment -%}
      <div class="tgp-product-actions">
        <a href="#" aria-label="Compare">
          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>
          Compare
        </a>
        <a href="/wishlist" aria-label="Add to wishlist">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Add to wishlist
        </a>
      </div>

      {%- comment -%} SKU / Category / Brand meta {%- endcomment -%}
      <div class="tgp-meta">
        {%- if product.selected_or_first_available_variant.sku != blank -%}
          <div class="tgp-meta__item"><strong>SKU:</strong> {{ product.selected_or_first_available_variant.sku }}</div>
        {%- endif -%}
        {%- if product.collections.first != blank -%}
          <div class="tgp-meta__item"><strong>Category:</strong> <a href="{{ product.collections.first.url }}" style="color:inherit;text-decoration:none">{{ product.collections.first.title }}</a></div>
        {%- endif -%}
        <div class="tgp-meta__item"><strong>Brand:</strong> Tatiana &amp; Glen</div>
      </div>

    </div>{%- comment -%} /tgp-info {%- endcomment -%}

  </section>{%- comment -%} /tgp-product {%- endcomment -%}

  {%- comment -%} ──────────── HORIZONTAL TABS ──────────── {%- endcomment -%}
  <div class="tgp-tabs" data-tgp-tabs>

    <div class="tgp-tabs__nav" role="tablist">
      {%- if product.description != blank -%}
        <button class="tgp-tab-btn is-active" data-tgp-tab-btn="description" role="tab" aria-selected="true">Description</button>
      {%- endif -%}
      <button class="tgp-tab-btn{% if product.description == blank %} is-active{% endif %}" data-tgp-tab-btn="additional" role="tab">Additional information</button>
      <button class="tgp-tab-btn" data-tgp-tab-btn="reviews" role="tab">Reviews (0)</button>
    </div>

    {%- comment -%} Description panel {%- endcomment -%}
    {%- if product.description != blank -%}
      <div class="tgp-tab-panel is-active" data-tgp-tab-panel="description" role="tabpanel">
        <div class="rte">{{ product.description }}</div>
      </div>
    {%- endif -%}

    {%- comment -%} Additional information panel {%- endcomment -%}
    <div class="tgp-tab-panel{% if product.description == blank %} is-active{% endif %}" data-tgp-tab-panel="additional" role="tabpanel">
      {%- liquid
        assign has_attrs = false
        if product.options_with_values.size > 0
          assign has_attrs = true
        endif
        if product.variants.first.weight > 0
          assign has_attrs = true
        endif
      -%}
      {%- if has_attrs -%}
        <table class="tgp-attrs">
          {%- if product.variants.first.weight > 0 -%}
            <tr>
              <td>Weight</td>
              <td>{{ product.variants.first.weight | weight_with_unit: product.variants.first.weight_unit }}</td>
            </tr>
          {%- endif -%}
          {%- for option in product.options_with_values -%}
            <tr>
              <td>{{ option.name }}</td>
              <td>{{ option.values | join: ', ' }}</td>
            </tr>
          {%- endfor -%}
          {%- if product.metafields.custom.dimensions != blank -%}
            <tr><td>Dimensions</td><td>{{ product.metafields.custom.dimensions }}</td></tr>
          {%- endif -%}
          {%- if product.metafields.custom.materials != blank -%}
            <tr><td>Materials</td><td>{{ product.metafields.custom.materials }}</td></tr>
          {%- endif -%}
          {%- if product.metafields.custom.origin != blank -%}
            <tr><td>Origin</td><td>{{ product.metafields.custom.origin }}</td></tr>
          {%- endif -%}
        </table>
      {%- else -%}
        <p>No additional information available.</p>
      {%- endif -%}
    </div>

    {%- comment -%} Reviews panel {%- endcomment -%}
    <div class="tgp-tab-panel" data-tgp-tab-panel="reviews" role="tabpanel">
      <p class="tgp-reviews-placeholder">There are no reviews yet.</p>
    </div>

  </div>{%- comment -%} /tgp-tabs {%- endcomment -%}

  {%- comment -%} ──────────── RELATED PRODUCTS ──────────── {%- endcomment -%}
  {%- if section.settings.show_related_products -%}
    {%- assign collection_products = product.collections.first.products -%}
    {%- assign shown_count = 0 -%}
    {%- assign has_related = false -%}
    {%- for rp in collection_products -%}
      {%- unless rp.id == product.id -%}
        {%- if shown_count < 4 -%}{%- assign has_related = true -%}{%- endif -%}
        {%- assign shown_count = shown_count | plus: 1 -%}
      {%- endunless -%}
    {%- endfor -%}

    {%- if has_related -%}
      <div class="tgp-related tgp-fade-in">
        <h2 class="tgp-related__heading">{{ section.settings.related_heading | default: 'Related products' }}</h2>
        <div class="tgp-related__grid">
          {%- assign shown_count = 0 -%}
          {%- for rp in collection_products -%}
            {%- unless rp.id == product.id -%}
              {%- if shown_count < 4 -%}
                <a href="{{ rp.url }}" class="tgp-related-card">
                  <div class="tgp-related-card__img-wrap">
                    {%- if rp.featured_image -%}
                      <img
                        src="{{ rp.featured_image | image_url: width: 600 }}"
                        alt="{{ rp.featured_image.alt | escape | default: rp.title }}"
                        class="tgp-related-card__img"
                        loading="lazy"
                        width="600"
                      >
                    {%- endif -%}
                  </div>
                  <h3 class="tgp-related-card__title">{{ rp.title }}</h3>
                  <p class="tgp-related-card__price">{{ rp.price_min | money }}</p>
                </a>
                {%- assign shown_count = shown_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} ──────────── TRUST BADGES ──────────── {%- endcomment -%}
  <div class="tgp-trust">
    <div class="tgp-trust__inner">

      <div class="tgp-trust__item">
        <div class="tgp-trust__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        </div>
        <div class="tgp-trust__body">
          <p class="tgp-trust__title">{{ section.settings.trust_1_title | default: 'Signed & Sealed Authenticity' }}</p>
          <p class="tgp-trust__text">{{ section.settings.trust_1_text | default: 'Every piece comes with a certificate of authenticity' }}</p>
        </div>
      </div>

      <div class="tgp-trust__item">
        <div class="tgp-trust__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="tgp-trust__body">
          <p class="tgp-trust__title">{{ section.settings.trust_2_title | default: 'Two Year Finish Commitment' }}</p>
          <p class="tgp-trust__text">{{ section.settings.trust_2_text | default: 'We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.' }}</p>
        </div>
      </div>

      <div class="tgp-trust__item">
        <div class="tgp-trust__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 11.5V9a2 2 0 00-4 0v3M14 9V7a2 2 0 00-4 0v4M10 8V6a2 2 0 00-4 0v7l-1-1a2 2 0 00-3 3l3 3a6 6 0 006 0h2a5 5 0 005-5v-4a2 2 0 00-4 0"/>
          </svg>
        </div>
        <div class="tgp-trust__body">
          <p class="tgp-trust__title">{{ section.settings.trust_3_title | default: 'Handled & Insured Delivery' }}</p>
          <p class="tgp-trust__text">{{ section.settings.trust_3_text | default: 'We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.' }}</p>
        </div>
      </div>

    </div>
  </div>

  {%- comment -%} ──────────── LIGHTBOX MODAL ──────────── {%- endcomment -%}
  <div class="tgp-lightbox" id="tgp-lightbox-{{ section.id }}" data-tgp-lightbox role="dialog" aria-modal="true" aria-label="Image gallery">
    <div class="tgp-lightbox__toolbar">
      <span class="tgp-lightbox__counter" data-tgp-lb-counter>1 / 1</span>
      <div class="tgp-lightbox__actions">
        <button class="tgp-lightbox__action-btn" data-tgp-lb-close aria-label="Close">
          <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <button class="tgp-lightbox__prev" data-tgp-lb-prev aria-label="Previous image">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <div class="tgp-lightbox__stage">
      <img class="tgp-lightbox__img" data-tgp-lb-img src="" alt="">
      <p class="tgp-lightbox__caption" data-tgp-lb-caption></p>
    </div>

    <button class="tgp-lightbox__next" data-tgp-lb-next aria-label="Next image">
      <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

</div>{%- comment -%} /tgp-root {%- endcomment -%}

{%- comment -%} Product data for JS {%- endcomment -%}
<script>
  window.tgpProductData = window.tgpProductData || {};
  window.tgpProductData['{{ section.id }}'] = {
    sectionId:        '{{ section.id }}',
    currentVariantId: {{ current_variant.id }},
    variants: {{ product.variants | json }},
    images: [
      {%- for img in product.images -%}
        { id: {{ img.id }}, src: '{{ img | image_url: width: 1200 }}', alt: '{{ img.alt | escape | default: product.title }}' }
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  };
</script>
<script src="{{ 'product-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "TG Product Page",
  "settings": [
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "text",
      "id": "trust_1_title",
      "label": "Badge 1 — Title",
      "default": "Signed & Sealed Authenticity"
    },
    {
      "type": "text",
      "id": "trust_1_text",
      "label": "Badge 1 — Text",
      "default": "Every piece comes with a certificate of authenticity"
    },
    {
      "type": "text",
      "id": "trust_2_title",
      "label": "Badge 2 — Title",
      "default": "Two Year Finish Commitment"
    },
    {
      "type": "text",
      "id": "trust_2_text",
      "label": "Badge 2 — Text",
      "default": "We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs."
    },
    {
      "type": "text",
      "id": "trust_3_title",
      "label": "Badge 3 — Title",
      "default": "Handled & Insured Delivery"
    },
    {
      "type": "text",
      "id": "trust_3_text",
      "label": "Badge 3 — Text",
      "default": "We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs."
    },
    {
      "type": "header",
      "content": "Related Products"
    },
    {
      "type": "checkbox",
      "id": "show_related_products",
      "label": "Show Related Products",
      "default": true
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "Section Heading",
      "default": "Related products"
    }
  ],
  "presets": [
    {
      "name": "TG Product Page"
    }
  ]
}
{% endschema %}
