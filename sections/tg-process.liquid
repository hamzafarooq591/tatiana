{% comment %} TatianaGlen — Our Process page {% endcomment %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap');

  .tgp-page {
    --tgp-gold:  #cd8f5c;
    --tgp-dark:  #111111;
    --tgp-text:  #666666;
    --tgp-cream: #f5ede4;
    --tgp-serif: 'Cormorant Garamond', Georgia, serif;
    --tgp-sans:  'Montserrat', Arial, sans-serif;
  }

  /* ============================================================
     HERO — full-width banner image
     ============================================================ */
  .tgp-hero {
    width: 100%;
    line-height: 0;
  }

  .tgp-hero__img {
    width: 100%;
    height: 600px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ============================================================
     PAGE TITLE — left-aligned below hero
     ============================================================ */
  .tgp-title {
    background: #ffffff;
    padding: 48px 80px 36px;
  }

  .tgp-title__heading {
    font-family: var(--tgp-serif);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 400;
    color: var(--tgp-dark);
    letter-spacing: 0.01em;
    line-height: 1.15;
    margin: 0;
    text-transform: none;
  }

  /* ============================================================
     BLOCK 1 — two craft images LEFT, two text sections RIGHT
     ============================================================ */
  .tgp-block1 {
    background: #ffffff;
    padding: 0 80px 72px;
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 64px;
    align-items: start;
  }

  .tgp-block1__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .tgp-block1__img {
    width: 100%;
    object-fit: cover;
    display: block;
  }

  .tgp-block1__img-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #e5ddd4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tgp-block1__img-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.2;
  }

  .tgp-block1__text {
    padding-top: 8px;
  }

  /* ============================================================
     SHARED TEXT BLOCK STYLES
     ============================================================ */
  .tgp-text-group {
    margin-bottom: 40px;
  }

  .tgp-text-group:last-child {
    margin-bottom: 0;
  }

  .tgp-text-group__heading {
    font-family: var(--tgp-sans);
    font-size: 34px;
    font-weight: 600 !important;
    color: var(--tgp-dark);
    letter-spacing: 0 !important;
    margin: 0 0 14px;
    text-transform: none;
    line-height: 1.3;
  }

  .tgp-text-group p {
    font-family: var(--tgp-sans);
    font-size: 16px;
    color: var(--tgp-text);
    line-height: 1.4em;
    margin: 0 0 10px;
  }

  .tgp-text-group p:last-child {
    margin-bottom: 0;
  }

  /* ============================================================
     BLOCK 2 — two large images side by side, no text
     ============================================================ */
  .tgp-block2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: #ffffff;
    padding: 0 80px 72px;
  }

  .tgp-block2__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    padding: 8%;
  }

  .tgp-block2__img-placeholder {
    width: 100%;
    height: 360px;
    background: #ddd5c9;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tgp-block2__img-placeholder svg {
    width: 60px;
    height: 60px;
    opacity: 0.2;
  }

  /* ============================================================
     BLOCK 3 — one large image LEFT, stacked text blocks RIGHT
     ============================================================ */
  .tgp-block3 {
    background: #ffffff;
    padding: 0 130px 80px;
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 64px;
    align-items: start;
  }

  .tgp-block3__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .tgp-block3__img-placeholder {
    width: 100%;
    height: 580px;
    background: #e5ddd4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tgp-block3__img-placeholder svg {
    width: 60px;
    height: 60px;
    opacity: 0.2;
  }

  .tgp-block3__text {
    padding-top: 8px;
    text-align: center;
  }

  /* ============================================================
     FEATURES — cream bg, icon-left horizontal
     ============================================================ */
  .tgp-features {
    background: var(--tgp-cream);
    padding: 64px 80px;
  }

  .tgp-features__grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .tgp-features__item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
  }

  .tgp-features__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--tgp-dark);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tgp-features__icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--tgp-dark);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tgp-features__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tgp-features__title {
    font-family: var(--tgp-sans);
    font-size: 13px;
    font-weight: 700;
    color: var(--tgp-dark);
    margin: 0;
  }

  .tgp-features__text {
    font-family: var(--tgp-sans);
    font-size: 12px;
    font-weight: 400;
    color: var(--tgp-text);
    line-height: 1.75;
    margin: 0;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media screen and (max-width: 989px) {
    .tgp-title  { padding: 40px 40px 28px; }
    .tgp-block1 { padding: 0 40px 56px; gap: 40px; }
    .tgp-block2 { padding: 0 40px 56px; }
    .tgp-block3 { padding: 0 40px 64px; gap: 40px; }
    .tgp-features { padding: 56px 40px; }
    .tgp-features__grid { grid-template-columns: repeat(2, 1fr); gap: 36px; }
  }

  @media screen and (max-width: 749px) {
    .tgp-hero__img { height: 260px; }
    .tgp-title  { padding: 32px 20px 20px; }
    .tgp-block1 { padding: 0 20px 48px; grid-template-columns: 1fr; gap: 32px; }
    .tgp-block2 { padding: 0 20px 48px; grid-template-columns: 1fr; }
    .tgp-block2__img,
    .tgp-block2__img-placeholder { height: 260px; }
    .tgp-block3 { padding: 0 20px 56px; grid-template-columns: 1fr; gap: 32px; }
    .tgp-block3__img,
    .tgp-block3__img-placeholder { height: 320px; }
    .tgp-features { padding: 48px 20px; }
    .tgp-features__grid { grid-template-columns: 1fr; gap: 32px; }
  }
{% endstyle %}

<div class="tgp-page">

  {%- comment -%} ========== HERO ========== {%- endcomment -%}
  <div class="tgp-hero">
    {%- if section.settings.hero_image != blank -%}
      <img class="tgp-hero__img"
        src="{{ section.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ section.settings.hero_image.alt | default: 'Our Process' | escape }}"
        loading="eager"
        width="{{ section.settings.hero_image.width }}"
        height="{{ section.settings.hero_image.height }}">
    {%- else -%}
      <img class="tgp-hero__img"
        src="https://cdn.shopify.com/s/files/1/0706/3525/8054/files/Our-Process-scaled.png"
        alt="Our Process — Tatiana &amp; Glen Studio"
        loading="eager">
    {%- endif -%}
  </div>

  {%- comment -%} ========== PAGE TITLE ========== {%- endcomment -%}
  <div class="tgp-title">
    <h1 class="tgp-title__heading">Our Process</h1>
  </div>

  {%- comment -%} ========== BLOCK 1: 2 craft images | 2 text sections ========== {%- endcomment -%}
  <div class="tgp-block1">

    <div class="tgp-block1__images">
      {%- if section.settings.craft_img1 != blank -%}
        <img class="tgp-block1__img"
          src="{{ section.settings.craft_img1 | image_url: width: 600 }}"
          alt="{{ section.settings.craft_img1.alt | default: 'Craft process' | escape }}"
          loading="lazy">
      {%- else -%}
        <img class="tgp-block1__img" src="https://cdn.shopify.com/s/files/1/0706/3525/8054/files/IMG_5564.jpg" alt="Craft process" loading="lazy">
      {%- endif -%}
      {%- if section.settings.craft_img2 != blank -%}
        <img class="tgp-block1__img"
          src="{{ section.settings.craft_img2 | image_url: width: 600 }}"
          alt="{{ section.settings.craft_img2.alt | default: 'Craft process' | escape }}"
          loading="lazy">
      {%- else -%}
        <img class="tgp-block1__img" src="https://cdn.shopify.com/s/files/1/0706/3525/8054/files/IMG_5563.png" alt="Craft process" loading="lazy">
      {%- endif -%}
    </div>

    <div class="tgp-block1__text">
      <div class="tgp-text-group">
        <h2 class="tgp-text-group__heading">Where Craft Meets Intention</h2>
        <p>Every Tatiana &amp; Glen piece begins in conversation — between material, light, and form.</p>
        <p>From our studio in Miami, each mirror is designed, poured, sanded, and finished by hand. We do not produce in volume. We create deliberately, one piece at a time.</p>
      </div>
      <div class="tgp-text-group">
        <h2 class="tgp-text-group__heading">Design &amp; Form</h2>
        <p>Each piece begins as a study in proportion and balance.</p>
        <p>Sketches explore silhouette, scale, and visual weight before any material is poured.</p>
        <p>Our work is rooted in restraint — form first, ornament second. Every curve and edge must feel intentional.</p>
      </div>
    </div>

  </div>

  {%- comment -%} ========== BLOCK 2: two large images side-by-side ========== {%- endcomment -%}
  <div class="tgp-block2">
    {%- if section.settings.room_img1 != blank -%}
      <img class="tgp-block2__img"
        src="{{ section.settings.room_img1 | image_url: width: 1200 }}"
        alt="{{ section.settings.room_img1.alt | default: 'Studio mirror' | escape }}"
        loading="lazy">
    {%- else -%}
      <img class="tgp-block2__img" src="https://cdn.shopify.com/s/files/1/0706/3525/8054/files/Process-2.png" alt="Studio mirror" loading="lazy">
    {%- endif -%}
    {%- if section.settings.room_img2 != blank -%}
      <img class="tgp-block2__img"
        src="{{ section.settings.room_img2 | image_url: width: 1200 }}"
        alt="{{ section.settings.room_img2.alt | default: 'Studio mirror' | escape }}"
        loading="lazy">
    {%- else -%}
      <img class="tgp-block2__img" src="https://cdn.shopify.com/s/files/1/0706/3525/8054/files/process-scaled.png" alt="Studio mirror" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment -%} ========== BLOCK 3: large image LEFT | 3 stacked text sections RIGHT ========== {%- endcomment -%}
  <div class="tgp-block3">

    <div class="tgp-block3__img-col">
      {%- if section.settings.finish_img != blank -%}
        <img class="tgp-block3__img"
          src="{{ section.settings.finish_img | image_url: width: 1200 }}"
          alt="{{ section.settings.finish_img.alt | default: 'Finishing process' | escape }}"
          loading="lazy">
      {%- else -%}
        <img class="tgp-block3__img" src="https://cdn.shopify.com/s/files/1/0706/3525/8054/files/IMG_5560.png" alt="Finishing process" loading="lazy">
      {%- endif -%}
    </div>

    <div class="tgp-block3__text">
      <div class="tgp-text-group">
        <h2 class="tgp-text-group__heading">Finishing &amp; Refinement</h2>
        <p>Once cured, every piece is sanded and refined by hand. Edges are examined from multiple angles. Surfaces are inspected under changing light.</p>
        <p>If a piece does not meet our standard, it does not leave the studio.</p>
        <p>We believe craftsmanship is respect — for the material and for the home it enters.</p>
      </div>
      <div class="tgp-text-group">
        <h2 class="tgp-text-group__heading">Made to Endure</h2>
        <p>Our mirrors are created with longevity in mind. Materials are selected for durability, clarity, and structural integrity.</p>
        <p>Each piece is accompanied by a certificate of authenticity and backed by our two-year finish commitment.</p>
      </div>
      <div class="tgp-text-group">
        <h2 class="tgp-text-group__heading">The Studio</h2>
        <p>Tatiana leads the making process with precision and discipline. Glen guides form, proportion, and conceptual direction.</p>
        <p>Together, our practice is quiet, focused, and unhurried.</p>
        <p>We make slowly — by choice.</p>
      </div>
    </div>

  </div>

  {%- comment -%} ========== FEATURES ========== {%- endcomment -%}
  <section class="tgp-features">
    <div class="tgp-features__grid">

      <div class="tgp-features__item">
        <div class="tgp-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <div class="tgp-features__body">
          <p class="tgp-features__title">Signed &amp; Sealed Authenticity</p>
          <p class="tgp-features__text">Every piece comes with a certificate of authenticity</p>
        </div>
      </div>

      <div class="tgp-features__item">
        <div class="tgp-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="tgp-features__body">
          <p class="tgp-features__title">Two Year Finish Commitment</p>
          <p class="tgp-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>

      <div class="tgp-features__item">
        <div class="tgp-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 11V6.5a2.5 2.5 0 0 0-5 0V12"/>
            <path d="M13 11.5V9a2 2 0 0 0-4 0v3"/>
            <path d="M9 12.5V11a2 2 0 0 0-4 0v4c0 3.31 2.69 6 6 6h2a5 5 0 0 0 5-5v-4a2 2 0 0 0-4 0"/>
          </svg>
        </div>
        <div class="tgp-features__body">
          <p class="tgp-features__title">Handled &amp; Insured Delivery</p>
          <p class="tgp-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>

    </div>
  </section>

</div>

{% schema %}
{
  "name": "Our Process",
  "settings": [
    {
      "type": "header",
      "content": "Hero Banner"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Full-width hero image"
    },
    {
      "type": "header",
      "content": "Block 1 — Two Craft Images"
    },
    {
      "type": "image_picker",
      "id": "craft_img1",
      "label": "Craft image 1 (left)"
    },
    {
      "type": "image_picker",
      "id": "craft_img2",
      "label": "Craft image 2 (right)"
    },
    {
      "type": "header",
      "content": "Block 2 — Two Room Images"
    },
    {
      "type": "image_picker",
      "id": "room_img1",
      "label": "Room image 1 (left)"
    },
    {
      "type": "image_picker",
      "id": "room_img2",
      "label": "Room image 2 (right)"
    },
    {
      "type": "header",
      "content": "Block 3 — Finishing Image"
    },
    {
      "type": "image_picker",
      "id": "finish_img",
      "label": "Finishing process image (left)"
    }
  ],
  "presets": [
    {
      "name": "Our Process"
    }
  ]
}
{% endschema %}
