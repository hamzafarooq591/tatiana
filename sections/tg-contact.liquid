{% comment %} TatianaGlen — Contact / Trade & Design Inquiries page {% endcomment %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap');

  .tgct-page {
    --tgct-gold:  #cd8f5c;
    --tgct-dark:  #111111;
    --tgct-text:  #666666;
    --tgct-cream: #f5ede4;
    --tgct-border:#e0d8d0;
    --tgct-serif: 'Cormorant Garamond', Georgia, serif;
    --tgct-sans:  'Montserrat', Arial, sans-serif;
    font-family: var(--tgct-sans);
    background: #ffffff;
  }

  /* ============================================================
     INTRO SECTION
     ============================================================ */
  .tgct-intro {
    background: #ffffff;
    padding: 96px 80px 72px;
    text-align: center;
  }

  .tgct-intro__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .tgct-intro__eyebrow {
    font-family: var(--tgct-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--tgct-gold);
    margin: 0 0 18px;
  }

  .tgct-intro__heading {
    font-family: var(--tgct-serif);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    color: var(--tgct-dark);
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0 0 20px;
    text-transform: none;
  }

  .tgct-intro__divider {
    width: 48px;
    height: 1px;
    background: var(--tgct-gold);
    margin: 0 auto 24px;
  }

  .tgct-intro__body {
    font-family: var(--tgct-sans);
    font-size: 13.5px;
    color: var(--tgct-text);
    line-height: 1.85;
    margin: 0;
  }

  /* ============================================================
     FORM SECTION
     ============================================================ */
  .tgct-form-section {
    background: #ffffff;
    padding: 0 80px 96px;
  }

  .tgct-form {
    max-width: 680px;
    margin: 0 auto;
  }

  .tgct-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .tgct-form__group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  .tgct-form__group--full {
    grid-column: 1 / -1;
  }

  .tgct-form__label {
    font-family: var(--tgct-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tgct-dark);
  }

  .tgct-form__required {
    color: var(--tgct-gold);
  }

  .tgct-form__input,
  .tgct-form__textarea {
    font-family: var(--tgct-sans);
    font-size: 13px;
    color: var(--tgct-dark);
    background: #ffffff;
    border: 1px solid var(--tgct-border);
    padding: 14px 16px;
    outline: none;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.2s;
    border-radius: 0;
    -webkit-appearance: none;
  }

  .tgct-form__input::placeholder,
  .tgct-form__textarea::placeholder {
    color: #bbb;
    font-size: 12px;
  }

  .tgct-form__input:focus,
  .tgct-form__textarea:focus {
    border-color: var(--tgct-dark);
  }

  .tgct-form__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .tgct-form__submit {
    display: inline-block;
    padding: 16px 48px;
    background: var(--tgct-dark);
    color: #ffffff;
    font-family: var(--tgct-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.25s;
    margin-top: 8px;
  }

  .tgct-form__submit:hover {
    background: var(--tgct-gold);
  }

  /* Success message */
  .tgct-form__success {
    display: none;
    text-align: center;
    padding: 32px;
    background: #f5f5f5;
    font-family: var(--tgct-sans);
    font-size: 14px;
    color: var(--tgct-dark);
  }

  /* ============================================================
     FEATURES STRIP
     ============================================================ */
  .tgct-features {
    background: var(--tgct-cream);
    padding: 64px 80px;
  }

  .tgct-features__grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .tgct-features__item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
  }

  .tgct-features__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--tgct-dark);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tgct-features__icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--tgct-dark);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tgct-features__body { display: flex; flex-direction: column; gap: 6px; }
  .tgct-features__title { font-family: var(--tgct-sans); font-size: 13px; font-weight: 700; color: var(--tgct-dark); margin: 0; }
  .tgct-features__text  { font-family: var(--tgct-sans); font-size: 12px; color: var(--tgct-text); line-height: 1.75; margin: 0; }

  /* RESPONSIVE */
  @media screen and (max-width: 989px) {
    .tgct-intro { padding: 72px 40px 56px; }
    .tgct-form-section { padding: 0 40px 72px; }
    .tgct-features { padding: 56px 40px; }
    .tgct-features__grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }

  @media screen and (max-width: 749px) {
    .tgct-intro { padding: 56px 20px 40px; }
    .tgct-form-section { padding: 0 20px 56px; }
    .tgct-form__row { grid-template-columns: 1fr; }
    .tgct-features { padding: 48px 20px; }
    .tgct-features__grid { grid-template-columns: 1fr; gap: 28px; }
  }
{% endstyle %}

<div class="tgct-page">

  {%- comment -%} INTRO {%- endcomment -%}
  <section class="tgct-intro">
    <div class="tgct-intro__inner">
      <p class="tgct-intro__eyebrow">Get In Touch</p>
      <h1 class="tgct-intro__heading">Trade &amp; Design Inquiries</h1>
      <div class="tgct-intro__divider"></div>
      <p class="tgct-intro__body">We collaborate with interior designers, architects, and creative studios seeking sculptural mirrors for residential and hospitality projects.</p>
      <p class="tgct-intro__body" style="margin-top:12px;">If you are sourcing for a client, requesting trade pricing, or exploring custom specifications, please complete the form below. Our studio will review your inquiry and respond directly.</p>
    </div>
  </section>

  {%- comment -%} FORM {%- endcomment -%}
  <section class="tgct-form-section">
    {%- form 'contact', class: 'tgct-form', id: 'tgct-contact-form' -%}

      {%- if form.posted_successfully? -%}
        <div class="tgct-form__success" style="display:block;">
          Thank you for your inquiry. Our studio will be in touch shortly.
        </div>
      {%- else -%}

        <div class="tgct-form__row">
          <div class="tgct-form__group">
            <label class="tgct-form__label" for="tgct-name">Full Name <span class="tgct-form__required">*</span></label>
            <input class="tgct-form__input" type="text" id="tgct-name" name="contact[name]" placeholder="Your full name" required autocomplete="name">
          </div>
          <div class="tgct-form__group">
            <label class="tgct-form__label" for="tgct-studio">Studio / Company <span class="tgct-form__required">*</span></label>
            <input class="tgct-form__input" type="text" id="tgct-studio" name="contact[studio]" placeholder="Studio or company name" required>
          </div>
        </div>

        <div class="tgct-form__row">
          <div class="tgct-form__group">
            <label class="tgct-form__label" for="tgct-email">Your E-mail <span class="tgct-form__required">*</span></label>
            <input class="tgct-form__input" type="email" id="tgct-email" name="contact[email]" placeholder="your@email.com" required autocomplete="email">
          </div>
          <div class="tgct-form__group">
            <label class="tgct-form__label" for="tgct-phone">Phone Number</label>
            <input class="tgct-form__input" type="tel" id="tgct-phone" name="contact[phone]" placeholder="+1 (000) 000-0000" autocomplete="tel">
          </div>
        </div>

        <div class="tgct-form__group">
          <label class="tgct-form__label" for="tgct-message">Message <span class="tgct-form__required">*</span></label>
          <textarea class="tgct-form__textarea" id="tgct-message" name="contact[body]" placeholder="Tell us about your project, timeline, and what you're looking for..." required></textarea>
        </div>

        <button class="tgct-form__submit" type="submit">Send Inquiry</button>

      {%- endif -%}
    {%- endform -%}
  </section>

  {%- comment -%} FEATURES {%- endcomment -%}
  <section class="tgct-features">
    <div class="tgct-features__grid">
      <div class="tgct-features__item">
        <div class="tgct-features__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="tgct-features__body">
          <p class="tgct-features__title">Signed &amp; Sealed Authenticity</p>
          <p class="tgct-features__text">Every piece comes with a certificate of authenticity</p>
        </div>
      </div>
      <div class="tgct-features__item">
        <div class="tgct-features__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div class="tgct-features__body">
          <p class="tgct-features__title">Two Year Finish Commitment</p>
          <p class="tgct-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>
      <div class="tgct-features__item">
        <div class="tgct-features__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 11V6.5a2.5 2.5 0 0 0-5 0V12"/><path d="M13 11.5V9a2 2 0 0 0-4 0v3"/><path d="M9 12.5V11a2 2 0 0 0-4 0v4c0 3.31 2.69 6 6 6h2a5 5 0 0 0 5-5v-4a2 2 0 0 0-4 0"/></svg></div>
        <div class="tgct-features__body">
          <p class="tgct-features__title">Handled &amp; Insured Delivery</p>
          <p class="tgct-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Contact Page",
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
