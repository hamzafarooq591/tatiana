{% comment %} TatianaGlen — About Us / Meet the Artist page section {% endcomment %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap');

  .tga-page {
    --tga-gold:  #cd8f5c;
    --tga-dark:  #111111;
    --tga-text:  #666666;
    --tga-cream: #f5ede4;
    --tga-serif: 'Cormorant Garamond', Georgia, serif;
    --tga-sans:  'Montserrat', Arial, sans-serif;
  }

  /* ============================================================
     ARTIST IMAGE — contained, centered, white bg
     ============================================================ */
  .tga-artist {
    background: #ffffff;
    padding: 72px 24px 0;
    text-align: center;
  }

  .tga-artist__img {
    display: block;
    margin: 0 auto;
    max-width: 1030px;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* ============================================================
     STORY SECTION — title below image, centered paragraphs
     ============================================================ */
  .tga-story {
    background: #ffffff;
    padding: 56px 24px 72px;
    text-align: center;
  }

  .tga-story__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .tga-story__heading {
    font-family: var(--tga-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--tga-dark);
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0 0 36px;
    text-transform: none;
  }

  .tga-story__body p {
    font-family: var(--tga-sans);
    font-size: 13.5px;
    font-weight: 400;
    color: var(--tga-text);
    line-height: 1.9;
    margin: 0 0 22px;
    text-align: center;
  }

  .tga-story__body p:last-child {
    margin-bottom: 0;
  }

  /* closing "When you bring…" paragraph — same style */
  .tga-story__wrap {
    margin-top: 22px;
  }

  .tga-story__wrap p {
    font-family: var(--tga-sans);
    font-size: 13.5px;
    font-weight: 400;
    color: var(--tga-text);
    line-height: 1.9;
    text-align: center;
    margin: 0;
  }

  /* Bold closing statement */
  .tga-story__statement {
    font-family: var(--tga-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.7rem);
    font-weight: 700;
    color: var(--tga-dark);
    text-align: center;
    letter-spacing: 0.01em;
    line-height: 1.5;
    margin: 40px auto 0;
    max-width: 700px;
    text-transform: none;
  }

  /* ============================================================
     FEATURES — cream bg, icon-left horizontal layout
     ============================================================ */
  .tga-features {
    background: var(--tga-cream);
    padding: 64px 80px;
  }

  .tga-features__grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .tga-features__item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
  }

  .tga-features__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--tga-dark);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tga-features__icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--tga-dark);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tga-features__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tga-features__title {
    font-family: var(--tga-sans);
    font-size: 13px;
    font-weight: 700;
    color: var(--tga-dark);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .tga-features__text {
    font-family: var(--tga-sans);
    font-size: 12px;
    font-weight: 400;
    color: var(--tga-text);
    line-height: 1.75;
    margin: 0;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media screen and (max-width: 989px) {
    .tga-features { padding: 56px 40px; }
    .tga-features__grid { grid-template-columns: repeat(2, 1fr); gap: 36px; }
  }

  @media screen and (max-width: 749px) {
    .tga-artist { padding: 48px 20px 0; }
    .tga-story { padding: 40px 20px 56px; }
    .tga-features { padding: 48px 20px; }
    .tga-features__grid { grid-template-columns: 1fr; gap: 32px; }
  }
{% endstyle %}

<div class="tga-page">

  {%- comment -%} ========== ARTIST IMAGE ========== {%- endcomment -%}
  <section class="tga-artist">
    {%- if section.settings.hero_image != blank -%}
      <img
        class="tga-artist__img"
        src="{{ section.settings.hero_image | image_url: width: 1240 }}"
        alt="{{ section.settings.hero_image.alt | default: 'Tatiana Glen' | escape }}"
        loading="eager"
        width="{{ section.settings.hero_image.width }}"
        height="{{ section.settings.hero_image.height }}"
      >
    {%- else -%}
      <img
        class="tga-artist__img"
        src="https://tatianaglen.com/wp-content/uploads/2026/03/Meet-the-artist-768x429.png"
        alt="Tatiana Glen — Meet the Artist"
        loading="eager"
        width="768"
        height="429"
      >
    {%- endif -%}
  </section>

  {%- comment -%} ========== STORY ========== {%- endcomment -%}
  <section class="tga-story">
    <div class="tga-story__inner">
      <h1 class="tga-story__heading">{{ section.settings.hero_title }}</h1>

      <div class="tga-story__body">
        <p>Tatiana &amp; Glen is a studio-led practice founded by partners Tatiana and Glen — artists, designers, and collaborators whose work is shaped by culture, travel, and a shared belief that beauty is essential to how we live.</p>
        <p>Tatiana's path began in Colombia, where art and craft are woven into daily life. Over more than a decade, she built her career transforming high-end residences for influential clients across three continents — from penthouses overlooking Central Park to historic European estates, from modern compounds in Medellín and Bogotá to minimalist sanctuaries throughout Latin America. Each project refined her understanding of how space, light, and proportion shape emotional experience.</p>
        <p>Glen was born in Jamaica, where the mystical and the practical coexist naturally. His early life was shaped by this duality — an intuitive sensibility alongside a deep curiosity for systems, patterns, and how things work. This perspective led him to approach design as both structure and feeling, where logic and intuition inform one another.</p>
        <p>Their paths crossed at an art opening in Bogotá. What began as a conversation became a shared language — a belief that the most meaningful design emerges from the balance between discipline and dreams.</p>
        <p>From their home and studio in Miami, they continue this exploration together, creating objects that invite people to slow down, notice, and live with intention.</p>
      </div>

      <div class="tga-story__wrap">
        <p>When you bring their work into your home, you are not simply acquiring an object.<br>You are joining a story that continues with you.</p>
      </div>

      <p class="tga-story__statement">This is who they are. This is why they create. This is a story that continues with you.</p>
    </div>
  </section>

  {%- comment -%} ========== FEATURES ========== {%- endcomment -%}
  <section class="tga-features">
    <div class="tga-features__grid">

      <div class="tga-features__item">
        <div class="tga-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <div class="tga-features__body">
          <p class="tga-features__title">Signed &amp; Sealed Authenticity</p>
          <p class="tga-features__text">Every piece comes with a certificate of authenticity</p>
        </div>
      </div>

      <div class="tga-features__item">
        <div class="tga-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="tga-features__body">
          <p class="tga-features__title">Two Year Finish Commitment</p>
          <p class="tga-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>

      <div class="tga-features__item">
        <div class="tga-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 11V6.5a2.5 2.5 0 0 0-5 0V12"/>
            <path d="M13 11.5V9a2 2 0 0 0-4 0v3"/>
            <path d="M9 12.5V11a2 2 0 0 0-4 0v4c0 3.31 2.69 6 6 6h2a5 5 0 0 0 5-5v-4a2 2 0 0 0-4 0"/>
          </svg>
        </div>
        <div class="tga-features__body">
          <p class="tga-features__title">Handled &amp; Insured Delivery</p>
          <p class="tga-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>

    </div>
  </section>

</div>

{% schema %}
{
  "name": "About Us",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Artist Photo"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Page Heading",
      "default": "The Artists Behind the Name"
    }
  ],
  "presets": [
    {
      "name": "About Us"
    }
  ]
}
{% endschema %}
