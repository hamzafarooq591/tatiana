{% comment %} TatianaGlen — About Us / Meet the Artist page section {% endcomment %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap');

  /* ============================================================
     CSS VARIABLES
     ============================================================ */
  .tga-page {
    --tga-gold:   #cd8f5c;
    --tga-dark:   #111111;
    --tga-text:   #666666;
    --tga-light:  #f5ede4;
    --tga-serif:  'Cormorant Garamond', Georgia, serif;
    --tga-sans:   'Montserrat', Arial, sans-serif;
  }

  /* ============================================================
     HERO
     ============================================================ */
  .tga-hero {
    position: relative;
    width: 100%;
    height: 520px;
    overflow: hidden;
  }

  .tga-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .tga-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.38);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tga-hero__title {
    font-family: var(--tga-serif);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 300;
    color: #ffffff;
    letter-spacing: 0.06em;
    text-align: center;
    margin: 0;
    text-transform: none;
    line-height: 1.2;
  }

  /* ============================================================
     STORY SECTION
     ============================================================ */
  .tga-story {
    background: #ffffff;
    padding: 96px 24px 80px;
  }

  .tga-story__inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .tga-story__eyebrow {
    font-family: var(--tga-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tga-gold);
    margin: 0 0 24px;
  }

  .tga-story__heading {
    font-family: var(--tga-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 300;
    color: var(--tga-dark);
    letter-spacing: 0.03em;
    line-height: 1.25;
    margin: 0 0 48px;
    text-transform: none;
  }

  .tga-story__divider {
    width: 48px;
    height: 1px;
    background: var(--tga-gold);
    margin: 0 auto 48px;
  }

  .tga-story__body {
    text-align: left;
  }

  .tga-story__body p {
    font-family: var(--tga-sans);
    font-size: 15px;
    font-weight: 400;
    color: var(--tga-text);
    line-height: 1.9;
    margin: 0 0 28px;
  }

  .tga-story__body p:last-child {
    margin-bottom: 0;
  }

  .tga-story__closing {
    font-family: var(--tga-serif);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    font-weight: 400;
    font-style: italic;
    color: var(--tga-dark);
    text-align: center;
    margin: 56px auto 0;
    max-width: 620px;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  /* ============================================================
     QUOTE BANNER
     ============================================================ */
  .tga-quote {
    background: var(--tga-light);
    padding: 72px 24px;
    text-align: center;
  }

  .tga-quote__inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .tga-quote__mark {
    font-family: var(--tga-serif);
    font-size: 4rem;
    color: var(--tga-gold);
    line-height: 0.5;
    margin-bottom: 24px;
    display: block;
  }

  .tga-quote__text {
    font-family: var(--tga-serif);
    font-size: clamp(1.3rem, 2.8vw, 1.9rem);
    font-weight: 300;
    font-style: italic;
    color: var(--tga-dark);
    line-height: 1.65;
    margin: 0 0 20px;
    letter-spacing: 0.02em;
  }

  .tga-quote__sub {
    font-family: var(--tga-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tga-gold);
    margin: 0;
  }

  /* ============================================================
     FEATURES / TRUST SECTION
     ============================================================ */
  .tga-features {
    background: #ffffff;
    padding: 96px 80px;
  }

  .tga-features__heading {
    font-family: var(--tga-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    color: var(--tga-dark);
    text-align: center;
    margin: 0 0 64px;
    letter-spacing: 0.03em;
    text-transform: none;
  }

  .tga-features__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .tga-features__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
  }

  .tga-features__icon {
    width: 64px;
    height: 64px;
    border: 1.5px solid var(--tga-dark);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tga-features__icon svg {
    width: 32px;
    height: 32px;
    stroke: var(--tga-dark);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tga-features__body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tga-features__title {
    font-family: var(--tga-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tga-dark);
    margin: 0;
  }

  .tga-features__text {
    font-family: var(--tga-sans);
    font-size: 13px;
    font-weight: 400;
    color: var(--tga-text);
    line-height: 1.75;
    margin: 0;
  }

  /* ============================================================
     NEWSLETTER / STAY CONNECTED
     ============================================================ */
  .tga-connect {
    background: var(--tga-dark);
    padding: 96px 24px;
    text-align: center;
  }

  .tga-connect__inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .tga-connect__eyebrow {
    font-family: var(--tga-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tga-gold);
    margin: 0 0 16px;
  }

  .tga-connect__heading {
    font-family: var(--tga-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 300;
    color: #ffffff;
    letter-spacing: 0.04em;
    margin: 0 0 14px;
    text-transform: none;
  }

  .tga-connect__sub {
    font-family: var(--tga-sans);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.75;
    margin: 0 0 40px;
  }

  .tga-connect__form {
    display: flex;
    gap: 0;
    width: 100%;
  }

  .tga-connect__input {
    flex: 1;
    padding: 15px 20px;
    font-family: var(--tga-sans);
    font-size: 13px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-right: none;
    color: #ffffff;
    outline: none;
    letter-spacing: 0.04em;
  }

  .tga-connect__input::placeholder {
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.08em;
    font-size: 11px;
    text-transform: uppercase;
  }

  .tga-connect__btn {
    padding: 15px 28px;
    background: var(--tga-gold);
    border: 1px solid var(--tga-gold);
    color: #ffffff;
    font-family: var(--tga-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .tga-connect__btn:hover {
    background: #bc753a;
    border-color: #bc753a;
  }

  .tga-connect__socials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 36px;
  }

  .tga-connect__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    transition: border-color 0.2s, background 0.2s;
  }

  .tga-connect__social-link:hover {
    border-color: var(--tga-gold);
    background: rgba(205, 143, 92, 0.1);
  }

  .tga-connect__social-link svg {
    width: 16px;
    height: 16px;
    fill: rgba(255, 255, 255, 0.7);
    stroke: none;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media screen and (max-width: 989px) {
    .tga-hero { height: 380px; }
    .tga-story { padding: 72px 24px 64px; }
    .tga-features { padding: 72px 40px; }
    .tga-features__grid { grid-template-columns: repeat(2, 1fr); gap: 36px; }
  }

  @media screen and (max-width: 749px) {
    .tga-hero { height: 280px; }
    .tga-story { padding: 56px 20px 48px; }
    .tga-quote { padding: 56px 20px; }
    .tga-features { padding: 56px 20px; }
    .tga-features__grid { grid-template-columns: 1fr; gap: 40px; }
    .tga-connect { padding: 64px 20px; }
    .tga-connect__form { flex-direction: column; }
    .tga-connect__input { border-right: 1px solid rgba(255,255,255,0.2); border-bottom: none; }
    .tga-connect__btn { padding: 15px 20px; }
  }
{% endstyle %}

<div class="tga-page">

  {%- comment -%} ========== HERO ========== {%- endcomment -%}
  <section class="tga-hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        class="tga-hero__img"
        src="{{ section.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        loading="eager"
        width="{{ section.settings.hero_image.width }}"
        height="{{ section.settings.hero_image.height }}"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'tga-hero__img' }}
    {%- endif -%}
    <div class="tga-hero__overlay">
      <h1 class="tga-hero__title">{{ section.settings.hero_title }}</h1>
    </div>
  </section>

  {%- comment -%} ========== STORY ========== {%- endcomment -%}
  <section class="tga-story">
    <div class="tga-story__inner">
      <p class="tga-story__eyebrow">Our Story</p>
      <h2 class="tga-story__heading">Tatiana &amp; Glen</h2>
      <div class="tga-story__divider"></div>
      <div class="tga-story__body">
        <p>Tatiana &amp; Glen is a studio-led practice founded by partners Tatiana and Glen — artists, designers, and collaborators whose work is shaped by culture, travel, and a shared belief that beauty is essential to how we live.</p>
        <p>Tatiana's path began in Colombia, where art and craft are woven into daily life. Over more than a decade, she built her career transforming high-end residences for influential clients across three continents — from penthouses overlooking Central Park to historic European estates, from modern compounds in Medellín and Bogotá to minimalist sanctuaries throughout Latin America. Each project refined her understanding of how space, light, and proportion shape emotional experience.</p>
        <p>Glen was born in Jamaica, where the mystical and the practical coexist naturally. His early life was shaped by this duality — an intuitive sensibility alongside a deep curiosity for systems, patterns, and how things work. This perspective led him to approach design as both structure and feeling, where logic and intuition inform one another.</p>
        <p>Their paths crossed at an art opening in Bogotá. What began as a conversation became a shared language — a belief that the most meaningful design emerges from the balance between discipline and dreams.</p>
        <p>From their home and studio in Miami, they continue this exploration together, creating objects that invite people to slow down, notice, and live with intention.</p>
      </div>
      <p class="tga-story__closing">When you bring their work into your home, you are not simply acquiring an object. You are joining a story that continues with you.</p>
    </div>
  </section>

  {%- comment -%} ========== QUOTE BANNER ========== {%- endcomment -%}
  <section class="tga-quote">
    <div class="tga-quote__inner">
      <span class="tga-quote__mark">&ldquo;</span>
      <p class="tga-quote__text">This is who they are. This is why they create. This is a story that continues with you.</p>
      <p class="tga-quote__sub">Tatiana &amp; Glen Studio — Miami</p>
    </div>
  </section>

  {%- comment -%} ========== FEATURES ========== {%- endcomment -%}
  <section class="tga-features">
    <h2 class="tga-features__heading">Our Commitments to You</h2>
    <div class="tga-features__grid">

      <div class="tga-features__item">
        <div class="tga-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <!-- Certificate / ribbon -->
            <rect x="3" y="3" width="14" height="18" rx="1.5"/>
            <path d="M7 8h6M7 12h6M7 16h3"/>
            <circle cx="18" cy="18" r="3"/>
            <path d="M15.5 20.5 14 23l2-1.5L18 23l-1.5-2.5"/>
          </svg>
        </div>
        <div class="tga-features__body">
          <p class="tga-features__title">Signed &amp; Sealed Authenticity</p>
          <p class="tga-features__text">Every piece comes with a certificate of authenticity, signed by the artists.</p>
        </div>
      </div>

      <div class="tga-features__item">
        <div class="tga-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <!-- Shield with checkmark -->
            <path d="M12 2L3 6v6c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V6L12 2z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        </div>
        <div class="tga-features__body">
          <p class="tga-features__title">Two Year Finish Commitment</p>
          <p class="tga-features__text">We guarantee finish and clarity for two years. Complimentary refinishing or replacement if natural wear occurs.</p>
        </div>
      </div>

      <div class="tga-features__item">
        <div class="tga-features__icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <!-- Box / delivery -->
            <path d="M21 16V8a2 2 0 0 0-1-1.73L13 2.27a2 2 0 0 0-2 0L4 6.27A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <div class="tga-features__body">
          <p class="tga-features__title">Handled &amp; Insured Delivery</p>
          <p class="tga-features__text">Each piece is carefully packed and fully insured during transit, so it arrives exactly as it left the studio.</p>
        </div>
      </div>

    </div>
  </section>

  {%- comment -%} ========== STAY CONNECTED ========== {%- endcomment -%}
  <section class="tga-connect">
    <div class="tga-connect__inner">
      <p class="tga-connect__eyebrow">Join the Studio</p>
      <h2 class="tga-connect__heading">Stay Connected</h2>
      <p class="tga-connect__sub">Occasional updates from the studio — new pieces, process, and releases.</p>

      {%- form 'customer', class: 'tga-connect__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          class="tga-connect__input"
          type="email"
          name="contact[email]"
          id="tga-connect-email"
          placeholder="Your email address"
          autocomplete="email"
          required
        >
        <button class="tga-connect__btn" type="submit">Subscribe</button>
      {%- endform -%}

      <div class="tga-connect__socials">
        {%- if settings.social_instagram_link != blank -%}
          <a class="tga-connect__social-link" href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a class="tga-connect__social-link" href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a class="tga-connect__social-link" href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "About Us",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Heading",
      "default": "The Artists Behind the Name"
    }
  ],
  "presets": [
    {
      "name": "About Us"
    }
  ]
}
{% endschema %}
