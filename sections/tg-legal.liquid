{% comment %} TatianaGlen — Reusable legal / policy page {% endcomment %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap');

  .tgl-page {
    --tgl-gold:   #cd8f5c;
    --tgl-dark:   #111111;
    --tgl-text:   #555555;
    --tgl-border: #e8e0d8;
    --tgl-serif:  'Cormorant Garamond', Georgia, serif;
    --tgl-sans:   'Montserrat', Arial, sans-serif;
    font-family: var(--tgl-sans);
    background: #ffffff;
  }

  /* ---- INTRO ---- */
  .tgl-intro {
    background: #ffffff;
    padding: 96px 80px 56px;
    text-align: center;
  }

  .tgl-intro__inner { max-width: 720px; margin: 0 auto; }

  .tgl-intro__eyebrow {
    font-family: var(--tgl-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--tgl-gold);
    margin: 0 0 18px;
  }

  .tgl-intro__heading {
    font-family: var(--tgl-serif);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    color: var(--tgl-dark);
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0 0 20px;
    text-transform: none;
  }

  .tgl-intro__divider {
    width: 48px;
    height: 1px;
    background: var(--tgl-gold);
    margin: 0 auto;
  }

  /* ---- CONTENT ---- */
  .tgl-content {
    max-width: 820px;
    margin: 0 auto;
    padding: 56px 80px 100px;
  }

  .tgl-content h1,
  .tgl-content h2 {
    font-family: var(--tgl-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tgl-dark);
    margin: 40px 0 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--tgl-border);
  }

  .tgl-content h3 {
    font-family: var(--tgl-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tgl-dark);
    margin: 28px 0 10px;
  }

  .tgl-content p {
    font-family: var(--tgl-sans);
    font-size: 13px;
    color: var(--tgl-text);
    line-height: 1.9;
    margin: 0 0 14px;
  }

  .tgl-content ul,
  .tgl-content ol {
    font-family: var(--tgl-sans);
    font-size: 13px;
    color: var(--tgl-text);
    line-height: 1.9;
    margin: 0 0 14px;
    padding-left: 24px;
  }

  .tgl-content li { margin-bottom: 6px; }

  .tgl-content strong { color: var(--tgl-dark); font-weight: 600; }

  .tgl-content a {
    color: var(--tgl-gold);
    text-decoration: none;
  }

  .tgl-content a:hover { text-decoration: underline; }

  /* ---- RESPONSIVE ---- */
  @media screen and (max-width: 989px) {
    .tgl-intro  { padding: 72px 40px 44px; }
    .tgl-content { padding: 44px 40px 80px; }
  }

  @media screen and (max-width: 749px) {
    .tgl-intro  { padding: 56px 20px 36px; }
    .tgl-content { padding: 36px 20px 64px; }
  }
{% endstyle %}

<div class="tgl-page">

  <section class="tgl-intro">
    <div class="tgl-intro__inner">
      <p class="tgl-intro__eyebrow">Legal</p>
      <h1 class="tgl-intro__heading">{{ page.title }}</h1>
      <div class="tgl-intro__divider"></div>
    </div>
  </section>

  <div class="tgl-content">
    {{ page.content }}
  </div>

</div>

{% schema %}
{
  "name": "Legal Page",
  "presets": [{ "name": "Legal Page" }]
}
{% endschema %}
