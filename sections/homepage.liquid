  .tg-instagram__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border: 1px solid var(--tg-border);
    color: var(--tg-text);
    text-decoration: none;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .tg-instagram__social-link:hover {
    border-color: var(--tg-primary);
    color: var(--tg-primary);
  }

  .tg-instagram__social-link svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  /* ============================================================
     SCROLL-IN ANIMATIONS
     ============================================================ */
  .tg-animate {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }

  .tg-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-animate--delay-1 { transition-delay: 0.10s; }
  .tg-animate--delay-2 { transition-delay: 0.20s; }
  .tg-animate--delay-3 { transition-delay: 0.32s; }
  .tg-animate--delay-4 { transition-delay: 0.44s; }

  /* ============================================================
     RESPONSIVE — TABLET (≤ 989px)
     ============================================================ */
  @media (max-width: 989px) {
    .tg-hero            { height: 560px; }
    .tg-hero__content   { padding: 0 40px; max-width: 560px; }
