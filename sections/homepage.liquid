<script>
(function () {
  'use strict';

  /* ============================================================
     HERO SLIDER
     ============================================================ */
  var hero   = document.getElementById('tg-hero');
  if (!hero) return;

  var slides  = hero.querySelectorAll('.tg-hero__slide');
  var dots    = hero.querySelectorAll('.tg-hero__dot');
  var btnPrev = document.getElementById('tg-hero-prev');
  var btnNext = document.getElementById('tg-hero-next');
  var current = 0;
  var total   = slides.length;
  var timer;

  function activate(index) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    dots[current].setAttribute('aria-selected', 'false');

    current = (index + total) % total;

    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function startTimer() {
    timer = setInterval(function () { activate(current + 1); }, 4000);
  }

  function stopTimer() { clearInterval(timer); }

  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      stopTimer(); activate(i); startTimer();
    });
  });

  if (btnPrev) btnPrev.addEventListener('click', function () {
    stopTimer(); activate(current - 1); startTimer();
  });

  if (btnNext) btnNext.addEventListener('click', function () {
    stopTimer(); activate(current + 1); startTimer();
  });

  /* Pause on hover */
  hero.addEventListener('mouseenter', stopTimer);
  hero.addEventListener('mouseleave', startTimer);

  /* Swipe support */
  var touchStartX = 0;
  hero.addEventListener('touchstart', function (e) {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  hero.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) {
      stopTimer();
      activate(dx < 0 ? current + 1 : current - 1);
      startTimer();
    }
  }, { passive: true });

  startTimer();

  /* ============================================================
     SCROLL-IN ANIMATIONS (IntersectionObserver)
     ============================================================ */
  var animateEls = document.querySelectorAll('.tg-animate');
  if (!animateEls.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

    animateEls.forEach(function (el) { observer.observe(el); });
  } else {
    /* Fallback: show all immediately */
    animateEls.forEach(function (el) { el.classList.add('is-visible'); });
  }

  /* ============================================================
     PRODUCT SLIDER
     ============================================================ */
  (function () {
    var wrap     = document.querySelector('.tg-product-slider-wrap');
    var slider   = document.getElementById('tg-product-slider');
    var dotsWrap = document.getElementById('tg-product-dots');
    if (!slider || !dotsWrap || !wrap) return;

    var cards    = Array.prototype.slice.call(slider.querySelectorAll('.tgc-card'));
    var total    = cards.length;
    var current  = 0;
    var gap      = 32;

    /* Responsive: how many cards per page */
    function perPage() {
      return wrap.offsetWidth < 600 ? 1 : wrap.offsetWidth < 900 ? 2 : 3;
    }

    function pages() {
      return Math.ceil(total / perPage());
    }

    /* Offset to card at index i — avoids empty last page */
    function offsetFor(page) {
      var pp     = perPage();
      var idx    = page * pp;
      /* Don't scroll past the last card */
      var maxIdx = Math.max(0, total - pp);
      idx = Math.min(idx, maxIdx);
      var cw = cards[0].offsetWidth + gap;
      return idx * cw;
    }

    function goTo(page) {
      current = Math.max(0, Math.min(page, pages() - 1));
      slider.style.transition = 'transform 0.5s ease';
      slider.style.transform  = 'translateX(-' + offsetFor(current) + 'px)';
      dotsWrap.querySelectorAll('.tg-product-dot').forEach(function (d, i) {
        d.classList.toggle('is-active', i === current);
      });
    }

    function buildDots() {
      dotsWrap.innerHTML = '';
      var p = pages();
      if (p <= 1) { dotsWrap.style.display = 'none'; return; }
      dotsWrap.style.display = '';
      for (var i = 0; i < p; i++) {
        var dot = document.createElement('button');
        dot.className = 'tg-product-dot' + (i === 0 ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Go to page ' + (i + 1));
        dot.dataset.page = i;
        dot.addEventListener('click', function () { goTo(parseInt(this.dataset.page)); });
        dotsWrap.appendChild(dot);
      }
    }

    buildDots();

    /* Rebuild on resize */
    window.addEventListener('resize', function () {
      slider.style.transition = 'none';
      slider.style.transform  = 'translateX(0)';
      current = 0;
      buildDots();
    }, { passive: true });

    /* Touch swipe */
    var touchX = 0;
    wrap.addEventListener('touchstart', function (e) { touchX = e.touches[0].clientX; }, { passive: true });
    wrap.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    }, { passive: true });
  })();

  /* ============================================================
     PARALLAX — Process section background
     ============================================================ */
  var processBg = document.querySelector('.tg-process__bg');
  if (processBg && window.matchMedia('(min-width: 990px)').matches) {
    window.addEventListener('scroll', function () {
      var section = processBg.parentElement;
      var rect    = section.getBoundingClientRect();
      var visible = rect.top < window.innerHeight && rect.bottom > 0;
      if (visible) {
        var ratio  = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        var offset = Math.round((ratio - 0.5) * 80);
        processBg.style.transform = 'translateY(' + offset + 'px)';
      }
    }, { passive: true });
  }

})();
</script>

<script src="{{ 'tatiana-quick-view.js' | asset_url }}"></script>
<script>
(function () {
  var root = document.querySelector('.tg-homepage');
  if (!root || typeof TatianaQuickView === 'undefined') return;
  if (!document.getElementById('tg-home-qv-overlay')) return;
  TatianaQuickView.init({ idRoot: 'tg-home-qv', triggerRoot: root });
})();
</script>

