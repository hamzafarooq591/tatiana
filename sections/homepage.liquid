{% comment %}
  TatianaGlen Homepage — Static Clone
  Source: https://tatianaglen.com/
  Sections (top→bottom, header & footer excluded):
    1. Hero Slider
    2. Category Blocks
    3. The Collection (Product Grid)
    4. Process Section
    5. Meet The Artist
    6. Craft & Commitment (Trust Badges)
    7. Instagram / Social
{% endcomment %}

{% comment %} Inject Google Fonts into <head> via Shopify's content_for_header hook {% endcomment %}
{%- capture tg_font_links -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Open+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
{%- endcapture -%}
{{ tg_font_links }}

<style>
  /* ============================================================
     HOMEPAGE CSS VARIABLES
     ============================================================ */
  .tg-homepage {
    --tg-primary:       #CD8F5C;
    --tg-primary-hover: #bc753a;
    --tg-secondary:     #EAF1F5;
    --tg-text:          #666666;
    --tg-accent:        #111111;
    --tg-border:        #EEEEEE;
    --tg-light:         #767676;
    --tg-cream:         #f7f1ed;
    --tg-dark-brown:    #5d2b09;
    --tg-serif:         'Cormorant Garamond', Georgia, serif;
    --tg-sans:          'Open Sans', Arial, sans-serif;
    font-family: var(--tg-sans);
  }

  /* Global heading override */
  h1, h2, h3, h4, .h0, .h1, .h2, .h3 {
    letter-spacing: -1.2px;
    font-weight: 400 !important;
  }

  /* ============================================================
     1. HERO SLIDER
     ============================================================ */
  .tg-hero {
    position: relative;
    width: 100%;
    height: 700px;
    overflow: hidden;
    background: #111;
  }

  .tg-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .tg-hero__slide.is-active {
    opacity: 1;
  }

  .tg-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.42);
  }

  .tg-hero__content {
    position: relative;
    z-index: 2;
    padding: 0 80px;
    max-width: 740px;
  }

  .tg-hero__heading {
    font-family: var(--tg-serif);
    font-size: 72px;
    font-weight: 400;
    line-height: 1.08;
    color: #ffffff;
    margin: 0 0 22px;
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.9s ease 0.3s, transform 0.9s ease 0.3s;
  }

  .tg-hero__slide.is-active .tg-hero__heading {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-hero__subheading {
    font-family: var(--tg-sans);
    font-size: 17px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.88);
    margin: 0 0 44px;
    line-height: 1.7;
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.9s ease 0.52s, transform 0.9s ease 0.52s;
  }

  .tg-hero__slide.is-active .tg-hero__subheading {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-hero__cta {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #111111;
    background: #ffffff;
    padding: 16px 38px;
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.9s ease 0.72s,
      transform 0.9s ease 0.72s,
      background 0.35s ease,
      color 0.35s ease;
  }

  .tg-hero__slide.is-active .tg-hero__cta {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-hero__cta:hover {
    background: var(--tg-primary);
    color: #ffffff;
  }

  /* Slide dots */
  .tg-hero__dots {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .tg-hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .tg-hero__dot.is-active {
    background: #ffffff;
    transform: scale(1.35);
  }

  /* Hero arrow nav */
  .tg-hero__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease;
    backdrop-filter: blur(4px);
  }

  .tg-hero__arrow:hover {
    background: rgba(255,255,255,0.25);
  }

  .tg-hero__arrow--prev { left: 24px; }
  .tg-hero__arrow--next { right: 24px; }

  .tg-hero__arrow svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ============================================================
     2. CATEGORY BLOCKS
     ============================================================ */
  .tg-categories-wrapper {
    background: #ffffff;
    padding: 70px 45px;
  }

  .tg-categories {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
  }

  .tg-category {
    position: relative;
    height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .tg-category__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.6s ease;
    filter: blur(0px);
  }

  .tg-category:hover .tg-category__bg {
    transform: scale(1.05);
    filter: blur(3px);
  }

  .tg-category__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    transition: background 0.4s ease;
  }

  .tg-category:hover .tg-category__overlay {
    background: rgba(0, 0, 0, 0.38);
  }

  .tg-category__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 10px;
    top: 30%;
  }

  .tg-category__title {
    font-family: var(--tg-serif);
    font-size: 47px;
    color: #ffffff;
    margin: 0 0 22px;
  }

  .tg-category__link {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #111111;
    background: #ffffff;
    border: 1px solid #ffffff;
    padding: 16px 42px;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .tg-category:hover .tg-category__link {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  /* ============================================================
     3. THE COLLECTION
     ============================================================ */
  .tg-collection {
    padding: 90px 80px;
    background: #ffffff;
  }

  .tg-section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .tg-section-header__title {
    font-family: var(--tg-serif);
    font-size: 48px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 22px;
    letter-spacing: 0.04em;
  }

  .tg-section-header__desc {
    font-family: var(--tg-sans);
    font-size: 15px;
    color: var(--tg-text);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.85;
  }

  .tg-product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 56px;
  }

  .tg-product-card {
    position: relative;
    cursor: pointer;
  }

  .tg-product-card__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 450 / 532;
    background: #f4ede6;
    margin-bottom: 18px;
  }

  .tg-product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tg-product-card:hover .tg-product-card__img {
    transform: scale(1.04);
  }

  .tg-product-card__actions {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 16px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 8px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .tg-product-card:hover .tg-product-card__actions {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-product-card__btn {
    display: block;
    width: 100%;
    padding: 13px;
    background: #ffffff;
    color: #111111;
    font-family: var(--tg-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .tg-product-card__btn:hover {
    background: var(--tg-primary);
    color: #ffffff;
  }

  .tg-product-card__secondary-actions {
    display: flex;
    gap: 6px;
  }

  .tg-product-card__icon-btn {
    flex: 1;
    padding: 9px 6px;
    background: rgba(255, 255, 255, 0.85);
    color: #111111;
    font-family: var(--tg-sans);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    border: none;
    cursor: pointer;
    transition: background 0.25s ease;
  }

  .tg-product-card__icon-btn:hover {
    background: #ffffff;
  }

  .tg-product-card__info {
    padding: 0 2px;
  }

  .tg-product-card__title {
    font-family: var(--tg-serif);
    font-size: 20px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 8px;
    letter-spacing: 0.02em;
    line-height: 1.35;
  }

  .tg-product-card__price {
    font-family: var(--tg-sans);
    font-size: 14px;
    color: var(--tg-text);
    margin: 0;
  }

  .tg-collection-footer {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  /* ============================================================
     SHARED BUTTON STYLES
     ============================================================ */
  .tg-btn-primary {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--tg-accent);
    padding: 17px 44px;
    text-decoration: none;
    transition: background 0.4s ease, transform 0.4s ease;
  }

  .tg-btn-primary:hover {
    background: var(--tg-primary);
    transform: translateY(-1px);
  }

  .tg-link-underline {
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tg-text);
    text-decoration: none;
    border-bottom: 1px solid var(--tg-border);
    padding-bottom: 4px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .tg-link-underline:hover {
    color: var(--tg-primary);
    border-color: var(--tg-primary);
  }

  /* ============================================================
     3b. QUOTE BANNER + SAGE BAND
     ============================================================ */
  .tg-quote-banner {
    position: relative;
    width: 100%;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-image: url('https://tatianaglen.com/wp-content/uploads/2026/03/Resina-home-scaled.png');
    background-size: cover;
    background-position: center;
    padding: 70px 80px;
    text-align: center;
  }

  .tg-quote-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 14, 8, 0.38);
  }

  .tg-quote-banner__text {
    position: relative;
    z-index: 2;
    max-width: 860px;
    font-family: var(--tg-serif);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.25;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }

  .tg-quote-banner__text em {
    font-style: italic;
    font-weight: 400;
  }

  .tg-sage-band {
    background: #b8c4af;
    padding: 48px 80px;
    text-align: center;
  }

  .tg-sage-band__text {
    font-family: var(--tg-serif);
    font-size: 22px;
    font-weight: 400;
    font-style: italic;
    color: #2a2a2a;
    margin: 0;
    letter-spacing: 0.01em;
  }

  @media (max-width: 989px) {
    .tg-quote-banner       { padding: 60px 40px; }
    .tg-quote-banner__text { font-size: 32px; }
    .tg-sage-band          { padding: 40px 40px; }
    .tg-sage-band__text    { font-size: 19px; }
  }

  @media (max-width: 749px) {
    .tg-quote-banner       { padding: 50px 24px; }
    .tg-quote-banner__text { font-size: 24px; letter-spacing: 0.04em; }
    .tg-sage-band          { padding: 36px 24px; }
    .tg-sage-band__text    { font-size: 17px; }
  }

  /* ============================================================
     4. PROCESS SECTION
     ============================================================ */
  .tg-process {
    position: relative;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 110px 60px;
    text-align: center;
    overflow: hidden;
  }

  .tg-process__bg {
    position: absolute;
    inset: 0;
    background-image: url('https://tatianaglen.com/wp-content/uploads/2026/03/Resina-home-scaled.png');
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  .tg-process__overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 8, 3, 0.58);
  }

  .tg-process__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .tg-process__quote {
    font-family: var(--tg-serif);
    font-size: 34px;
    font-weight: 300;
    font-style: italic;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.55;
    margin: 0 0 44px;
    letter-spacing: 0.01em;
  }

  .tg-process__divider {
    width: 56px;
    height: 1px;
    background: rgba(205, 143, 92, 0.7);
    margin: 0 auto 44px;
  }

  .tg-process__subheading {
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--tg-primary);
    margin: 0 0 28px;
  }

  .tg-process__cta-heading {
    font-family: var(--tg-serif);
    font-size: 52px;
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 30px;
    line-height: 1.18;
    letter-spacing: 0.02em;
  }

  .tg-process__desc {
    font-family: var(--tg-sans);
    font-size: 15px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.9;
    margin: 0 0 44px;
  }

  .tg-btn-outline {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.65);
    padding: 16px 38px;
    text-decoration: none;
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  .tg-btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #ffffff;
  }

  /* ============================================================
     5. MEET THE ARTIST
     ============================================================ */
  .tg-artist {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 580px;
  }

  .tg-artist__img-side {
    position: relative;
    overflow: hidden;
    min-height: 460px;
  }

  .tg-artist__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tg-artist__img-side:hover .tg-artist__img {
    transform: scale(1.04);
  }

  .tg-artist__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 80px;
    background: var(--tg-cream);
  }

  .tg-artist__label {
    font-family: var(--tg-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--tg-primary);
    margin-bottom: 22px;
    display: block;
  }

  .tg-artist__heading {
    font-family: var(--tg-serif);
    font-size: 40px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 28px;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .tg-artist__bio {
    font-family: var(--tg-sans);
    font-size: 14px;
    color: var(--tg-text);
    line-height: 1.95;
    margin: 0 0 18px;
  }

  .tg-artist__bio:last-of-type {
    margin-bottom: 36px;
  }

  .tg-artist__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--tg-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tg-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--tg-accent);
    padding-bottom: 5px;
    transition: color 0.3s ease, border-color 0.3s ease;
    width: fit-content;
  }

  .tg-artist__link:hover {
    color: var(--tg-primary);
    border-color: var(--tg-primary);
  }

  /* ============================================================
     6. CRAFT & COMMITMENT
     ============================================================ */
  .tg-trust {
    padding: 90px 80px;
    background: #ffffff;
    text-align: center;
  }

  .tg-trust__heading {
    font-family: var(--tg-serif);
    font-size: 38px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 64px;
    letter-spacing: 0.04em;
  }

  .tg-trust__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    max-width: 960px;
    margin: 0 auto;
  }

  .tg-trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .tg-trust__icon {
    width: 68px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tg-trust__icon svg {
    width: 52px;
    height: 52px;
    stroke: var(--tg-dark-brown);
    fill: none;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tg-trust__item-title {
    font-family: var(--tg-serif);
    font-size: 21px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 10px;
    letter-spacing: 0.02em;
    line-height: 1.3;
  }

  .tg-trust__item-desc {
    font-family: var(--tg-sans);
    font-size: 14px;
    color: var(--tg-text);
    line-height: 1.75;
    margin: 0;
    max-width: 260px;
  }

  /* ============================================================
     7. INSTAGRAM / SOCIAL
     ============================================================ */
  .tg-instagram {
    padding: 90px 80px;
    background: var(--tg-cream);
    text-align: center;
  }

  .tg-instagram__heading {
    font-family: var(--tg-serif);
    font-size: 44px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 14px;
    letter-spacing: 0.02em;
  }

  .tg-instagram__subtext {
    font-family: var(--tg-sans);
    font-size: 15px;
    color: var(--tg-text);
    margin: 0 0 36px;
  }

  .tg-instagram__social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .tg-instagram__follow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--tg-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--tg-accent);
    padding: 15px 32px;
    text-decoration: none;
    transition: background 0.35s ease, transform 0.35s ease;
  }

  .tg-instagram__follow:hover {
    background: var(--tg-primary);
    transform: translateY(-1px);
  }

  .tg-instagram__follow svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .tg-instagram__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border: 1px solid var(--tg-border);
    color: var(--tg-text);
    text-decoration: none;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .tg-instagram__social-link:hover {
    border-color: var(--tg-primary);
    color: var(--tg-primary);
