{% comment %}
  TatianaGlen Homepage — Static Clone
  Source: https://tatianaglen.com/
  Sections (top→bottom, header & footer excluded):
    1. Hero Slider
    2. Category Blocks
    3. The Collection (Product Grid)
    4. Process Section
    5. Meet The Artist
    6. Craft & Commitment (Trust Badges)
    7. Instagram / Social
{% endcomment %}

{% comment %} Inject Google Fonts into <head> via Shopify's content_for_header hook {% endcomment %}
{%- capture tg_font_links -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&family=Open+Sans:wght@300;400;500;600&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{%- endcapture -%}
{{ tg_font_links }}

<style>
  /* ============================================================
     HOMEPAGE CSS VARIABLES
     ============================================================ */
  .tg-homepage {
    --tg-primary:       #CD8F5C;
    --tg-primary-hover: #bc753a;
    --tg-secondary:     #EAF1F5;
    --tg-text:          #666666;
    --tg-accent:        #111111;
    --tg-border:        #EEEEEE;
    --tg-light:         #767676;
    --tg-cream:         #f7f1ed;
    --tg-dark-brown:    #5d2b09;
    --tg-serif:         'Cormorant Garamond', Georgia, serif;
    --tg-sans:          'Open Sans', Arial, sans-serif;
    font-family: var(--tg-sans);
  }

  /* Global heading override — capitalize, never uppercase */
  .tg-homepage h1,
  .tg-homepage h2,
  .tg-homepage h3,
  .tg-homepage h4,
  .tg-homepage h5,
  .tg-homepage h6,

  /* Buttons and CTAs stay uppercase */
  .tg-btn-primary,
  .tg-btn-outline,
  .tg-link-underline,
  .tg-hero__cta,
  .tg-category__link,
  .tgc-card__icon-btn,
  .tg-artist__link,
  .tg-instagram__follow {
    text-transform: uppercase !important;
  }

  /* ============================================================
     1. HERO SLIDER
     ============================================================ */
  .tg-hero {
    position: relative;
    width: 100%;
    height: 900px;
    overflow: hidden;
    background: #111;
  }

  .tg-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .tg-hero__slide.is-active {
    opacity: 1;
  }

  .tg-hero__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .tg-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
  }

  .tg-hero__content {
    position: relative;
    z-index: 2;
    padding: 0 80px;
    max-width: 740px;
    padding-top: 20%;
  }

  .tg-hero__heading {
    font-family: var(--tg-serif);
    font-size: 72px;
    font-weight: 400;
    line-height: 1;
    color: #ffffff;
    margin: 0 0 10px;
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.9s ease 0.3s, transform 0.9s ease 0.3s;
  }

  .tg-hero__slide.is-active .tg-hero__heading {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-hero__subheading {
    font-family: "Open Sans", sans-serif;
    font-size: 23px;
    font-weight: 400;
    font-style: italic;
    color: rgb(255, 255, 255);
    margin: 0 0 20px;
    line-height: 1.4em;
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.9s ease 0.52s, transform 0.9s ease 0.52s;
  }

  .tg-hero__slide.is-active .tg-hero__subheading {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-hero__cta {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #111111;
    background: #ffffff;
    padding: 16px 38px;
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s ease 0.72s, transform 0.9s ease 0.72s, background 0.35s ease, color 0.35s ease;
  }

  .tg-hero__slide.is-active .tg-hero__cta {
    opacity: 1;
    transform: translateY(0);
  }

  .tg-hero__cta:hover {
    background: var(--tg-primary);
    color: #ffffff;
  }

  /* Slide dots */
  .tg-hero__dots {
    position: absolute;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 10;
  }

  .tg-hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .tg-hero__dot.is-active {
    background: #ffffff;
    transform: scale(1.35);
  }

  /* Hero arrow nav */
  .tg-hero__arrow {
    display: none !important;
  }
  .tg-hero__arrow--hide {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease;
    backdrop-filter: blur(4px);
  }

  .tg-hero__arrow:hover {
    background: rgba(255,255,255,0.25);
  }

  .tg-hero__arrow--prev { left: 24px; }
  .tg-hero__arrow--next { right: 24px; }

  .tg-hero__arrow svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ============================================================
     2. CATEGORY BLOCKS
     ============================================================ */
  .tg-categories-wrapper {
    background: #ffffff;
    padding: 70px 45px;
  }

  .tg-categories {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
  }

  .tg-category {
    position: relative;
    height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .tg-category__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.6s ease;
    filter: blur(0px);
  }

  .tg-category:hover .tg-category__bg {
    transform: scale(1.05);
    filter: blur(3px);
  }

  .tg-category__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    transition: background 0.4s ease;
  }

  .tg-category:hover .tg-category__overlay {
    background: rgba(0, 0, 0, 0.38);
  }

  .tg-category__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 10px;
    top: 30%;
  }

  .tg-category__title {
    font-family: var(--tg-serif);
    font-size: 47px;
    color: #ffffff;
    margin: 0 0 10px;
  }

  .tg-category__link {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #111111;
    background: #ffffff;
    border: 1px solid #ffffff;
    padding: 16px 42px;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .tg-category:hover .tg-category__link {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  /* ============================================================
     3. THE COLLECTION
     ============================================================ */
  .tg-collection {
    padding: 110px 80px;
    background: #ffffff;
  }

  .tg-section-header {
    text-align: center;
    margin-bottom: 44px;
  }

  .tg-section-header__title {
    font-family: var(--tg-serif);
    font-size: 48px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 22px;
    letter-spacing: 0.04em;
  }

  .tg-section-header__desc {
    font-family: var(--tg-sans);
    font-size: 15px;
    color: var(--tg-text);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.85;
  }

  /* Product Slider */
  .tg-product-slider-wrap {
    position: relative;
    margin-bottom: 48px;
    overflow: hidden; /* clip here, NOT on the track */
  }

  .tg-product-grid {
    display: flex;
    gap: 32px;
    will-change: transform;
    /* transition set via JS */
  }

  /* Shared cards: snippets/tg-product-card.liquid + tg-quick-view-modal.liquid */
  .tg-homepage .tg-collection .tg-product-slider-wrap {
    --tgc-gold: var(--tg-primary);
    --tgc-dark: var(--tg-accent);
    --tgc-text: var(--tg-text);
    --tgc-border: var(--tg-border);
    --tgc-serif: var(--tg-serif);
    --tgc-sans: var(--tg-sans);
  }

  .tg-homepage .tg-collection .tgc-qv-overlay,
  .tg-homepage .tg-collection .tgc-qv-modal {
    --tgc-gold: var(--tg-primary);
    --tgc-dark: var(--tg-accent);
    --tgc-text: var(--tg-text);
    --tgc-border: var(--tg-border);
    --tgc-serif: var(--tg-serif);
    --tgc-sans: var(--tg-sans);
  }

  .tg-product-grid .tgc-card {
    flex: 0 0 calc((100% - 64px) / 3);
    min-width: 0;
  }

  .tg-product-grid .tgc-card__img-wrap {
    margin-bottom: 18px;
  }

  .tg-product-grid .tgc-card__actions {
    bottom: 16px;
    gap: 10px;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .tg-product-grid .tgc-card__icon-btn {
    width: 44px;
    height: 44px;
  }

  .tg-product-grid .tgc-card__icon-btn:hover {
    background: var(--tg-primary);
  }

  .tg-product-grid .tgc-card__icon-btn svg {
    width: 18px;
    height: 18px;
  }

  .tg-product-grid .tgc-card__info {
    padding: 0 2px;
  }

  .tg-product-grid .tgc-card__title {
    font-family: var(--tg-sans);
    font-size: 20px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 8px;
    letter-spacing: 0.02em;
    line-height: 1.35;
  }

  .tg-product-grid .tgc-card__price {
    font-family: var(--tg-sans);
    font-size: 16px;
    font-weight: 600;
    color: #111111;
  }

  .tg-product-grid .tgc-card__sold-out {
    color: var(--tg-light);
    font-size: 12px;
  }

  .tg-placeholder {
    background: #f4ede6;
  }

  /* Slider dots */
  .tg-product-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-top: 48px;
  }

  .tg-product-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d0d0d0;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: width 0.35s ease, border-radius 0.35s ease, background 0.35s ease;
  }

  .tg-product-dot.is-active {
    width: 28px;
    border-radius: 4px;
    background: var(--tg-primary);
  }

  .tg-collection-footer {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  /* ============================================================
     SHARED BUTTON STYLES
     ============================================================ */
  .tg-btn-primary {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--tg-accent);
    padding: 17px 44px;
    text-decoration: none;
    transition: background 0.4s ease, transform 0.4s ease;
  }

  .tg-btn-primary:hover {
    background: var(--tg-primary);
    transform: translateY(-1px);
  }

  .tg-link-underline {
    padding: 16px 41px;
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    color: #FFFFFF;
    border-style: solid;
    border-width: 2px;
    border-color: var(--tg-primary);
    border-radius: 0;
    background-color: #111111;
    text-decoration: none;
    display: inline-block;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .tg-link-underline:hover {
    color: var(--tg-primary);
    border-color: var(--tg-primary);
  }

  /* ============================================================
     3b. QUOTE BANNER + SAGE BAND
     ============================================================ */
  .tg-quote-banner {
    position: relative;
    width: 100%;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-image: url('https://cdn.shopify.com/s/files/1/0706/3525/8054/files/2-1.png');
    background-size: cover;
    background-position: center;
    padding: 70px 80px;
    text-align: center;
  }

  .tg-quote-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 14, 8, 0.38);
  }

  .tg-quote-banner__text {
    position: relative;
    z-index: 2;
    max-width: 860px;
    font-family: var(--tg-serif);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.25;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }

  .tg-quote-banner__text em {
    font-style: italic;
    font-weight: 400;
  }

  .tg-sage-band {
    background: #b8c4af;
    padding: 48px 80px;
    text-align: center;
  }

  .tg-sage-band__text {
    font-family: var(--tg-serif);
    font-size: 22px;
    font-weight: 400;
    font-style: italic;
    color: #2a2a2a;
    margin: 0;
    letter-spacing: 0.01em;
  }

  @media (max-width: 989px) {
    .tg-quote-banner       { padding: 60px 40px; }
    .tg-quote-banner__text { font-size: 32px; }
    .tg-sage-band          { padding: 40px 40px; }
    .tg-sage-band__text    { font-size: 19px; }
  }

  @media (max-width: 749px) {
    .tg-quote-banner       { padding: 50px 24px; }
    .tg-quote-banner__text { font-size: 24px; letter-spacing: 0.04em; }
    .tg-sage-band          { padding: 36px 24px; }
    .tg-sage-band__text    { font-size: 17px; }
  }

  /* ============================================================
     4. PROCESS SECTION
     ============================================================ */
  .tg-process {
    position: relative;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 110px 60px;
    text-align: center;
    overflow: hidden;
  }

  .tg-process__bg {
    position: absolute;
    inset: 0;
    background-image: url('https://cdn.shopify.com/s/files/1/0706/3525/8054/files/Resina-home-scaled.png');
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  .tg-process__overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 8, 3, 0.58);
  }

  .tg-process__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .tg-process__quote {
    font-family: var(--tg-serif);
    font-size: 34px;
    font-weight: 300;
    font-style: italic;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.55;
    margin: 0 0 44px;
    letter-spacing: 0.01em;
  }

  .tg-process__divider {
    width: 56px;
    height: 1px;
    background: rgba(205, 143, 92, 0.7);
    margin: 0 auto 44px;
  }

  .tg-process__subheading {
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--tg-primary);
    margin: 0 0 28px;
  }

  .tg-process__cta-heading {
    font-family: var(--tg-serif);
    font-size: 52px;
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 30px;
    line-height: 1.18;
    letter-spacing: 0.02em;
  }

  .tg-process__desc {
    font-family: var(--tg-sans);
    font-size: 15px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.9;
    margin: 0 0 44px;
  }

  .tg-btn-outline {
    display: inline-block;
    font-family: var(--tg-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.65);
    padding: 16px 38px;
    text-decoration: none;
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  .tg-btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #ffffff;
  }

  /* ============================================================
     5. MEET THE ARTIST
     ============================================================ */
  .tg-artist {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 580px;
  }

  .tg-artist__img-side {
    position: relative;
    overflow: hidden;
    min-height: 460px;
  }

  .tg-artist__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tg-artist__img-side:hover .tg-artist__img {
    transform: scale(1.04);
  }

  .tg-artist__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 80px;
    background: var(--tg-cream);
  }

  .tg-artist__label {
    font-family: var(--tg-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--tg-primary);
    margin-bottom: 22px;
    display: block;
  }

  .tg-artist__heading {
    font-family: var(--tg-serif);
    font-size: 40px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 28px;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .tg-artist__bio {
    font-family: var(--tg-sans);
    font-size: 14px;
    color: var(--tg-text);
    line-height: 1.95;
    margin: 0 0 18px;
  }

  .tg-artist__bio:last-of-type {
    margin-bottom: 36px;
  }

  .tg-artist__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--tg-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tg-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--tg-accent);
    padding-bottom: 5px;
    transition: color 0.3s ease, border-color 0.3s ease;
    width: fit-content;
  }

  .tg-artist__link:hover {
    color: var(--tg-primary);
    border-color: var(--tg-primary);
  }

  /* ============================================================
     6. CRAFT & COMMITMENT
     ============================================================ */
  .tg-trust {
    --tg-trust-bg-mid: #ede8e1;
    padding: 90px 60px;
    position: relative;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
    background-color: var(--tg-trust-bg-mid);
    box-shadow: inset 0 1px 0 0 rgba(205, 143, 92, 0.35);
    background-image:
      radial-gradient(ellipse 90% 130% at 8% 45%, rgba(205, 143, 92, 0.26) 0%, transparent 55%),
      radial-gradient(ellipse 75% 100% at 92% 60%, rgba(165, 198, 212, 0.32) 0%, transparent 50%),
      radial-gradient(ellipse 60% 80% at 50% -8%, rgba(255, 232, 214, 0.85) 0%, transparent 42%),
      radial-gradient(ellipse 70% 55% at 50% 108%, rgba(205, 143, 92, 0.12) 0%, transparent 50%),
      linear-gradient(
        168deg,
        #fcf7f1 0%,
        #ebe4da 24%,
        var(--tg-trust-bg-mid) 50%,
        #e5eef0 76%,
        #f8f3ec 100%
      );
  }

  .tg-trust::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 0%,
      rgba(255, 255, 255, 0.42) 35%,
      transparent 58%,
      rgba(205, 143, 92, 0.09) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  .tg-trust::after {
    content: '';
    position: absolute;
    width: 140%;
    height: 55%;
    left: -20%;
    bottom: -25%;
    background: radial-gradient(
      ellipse closest-side,
      rgba(232, 196, 168, 0.45) 0%,
      transparent 75%
    );
    pointer-events: none;
    z-index: 0;
  }

  .tg-trust > * {
    position: relative;
    z-index: 1;
  }

  .tg-trust__heading {
    font-family: var(--tg-serif);
    font-size: 38px;
    font-weight: 400;
    color: var(--tg-accent);
    margin: 0 0 64px;
    letter-spacing: 0.04em;
  }

  .tg-trust__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    width: 100%;
  }

  .tg-trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    padding: 32px 24px 36px;
    border-radius: 20px;
