  .tg-instagram__follow:hover {
    color: var(--tg-primary);
    border-color: var(--tg-primary);
  }

  .tg-instagram__follow svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
    flex-shrink: 0;
