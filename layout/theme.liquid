<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    {%- comment -%} TatianaGlen: Hide ShopPay installments banner sitewide {%- endcomment -%}
    <style>
      .installments,
      shopify-payment-terms,
      .payment-terms,
      [class*="installment"],
      [id*="installment"] {
        display: none !important;
        visibility: hidden !important;
        height: 0 !important;
        overflow: hidden !important;
      }

      /* TatianaGlen: Nav — matches tatianaglen.com exactly */
      .menu-list__item a,
      .header-menu a,
      header-menu a,
      [class*="menu-list"] a {
        font-family: 'Poppins', Sans-serif !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        color: #CECECE !important;
        letter-spacing: 0em !important;
        text-transform: uppercase !important;
        text-decoration: none !important;
        transition: color 0.2s ease !important;
        padding: 0 18px !important;
      }

      /* Active / current page link — amber underline */
      .menu-list__item--active > a,
      .menu-list__item[aria-current] > a,
      [aria-current="page"],
      .menu-list__item.is-active > a {
        color: #CECECE !important;
        border-bottom: 2px solid #CD8F5C !important;
        padding-bottom: 2px !important;
      }

      /* Hover — amber */
      .menu-list__item a:hover,
      header-menu a:hover {
        color: #CD8F5C !important;
        text-decoration: none !important;
      }

      /* TatianaGlen: Transparent header overlay on homepage.
         Horizon theme JS positions header-component absolutely when transparent;
         we ensure #header-group collapses so the hero fills from the very top. */
      body.template-index #header-group {
        height: 0;
        overflow: visible;
        position: relative;
        z-index: 100;
      }

      body.template-index #MainContent {
        margin-top: 0 !important;
        padding-top: 0 !important;
      }

      /* Header action icons — color matches nav */
      .header-actions__action {
        cursor: pointer !important;
        color: #CECECE !important;
      }

      /* Hide mobile header row */
      .header__row--mobile {
        display: none !important;
      }

      /* Mobile drawer hamburger icon */
      .menu-drawer-container .header__icon--summary {
        color: rgba(227, 227, 227, 1) !important;
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        padding: var(--padding-lg) !important;
      }

      /* ============================================================
         TatianaGlen: Mobile menu drawer — matches tatianaglen.com
         ============================================================ */

      /* Drawer background — cream, override all color scheme classes */
      .menu-drawer-container .menu-drawer,
      .menu-drawer-container [data-header-drawer],
      #Details-menu-drawer-container .menu-drawer,
      .menu-drawer.color-scheme-1,
      .menu-drawer.color-scheme-2,
      .menu-drawer.color-scheme-3,
      .menu-drawer.color-scheme-4,
      .menu-drawer.color-scheme-5,
      .menu-drawer.color-scheme-6,
      .menu-drawer {
        background: #f0e2d0 !important;
        background-color: #f0e2d0 !important;
        --color-background: 240, 226, 208 !important;
        box-shadow: none !important;
      }

      /* Close button — dark, top-right */
      .menu-drawer__close-button {
        color: #1a1008 !important;
        background: transparent !important;
        border: none !important;
      }

      .menu-drawer__close-button svg,
      .menu-drawer__close-button .svg-wrapper,
      .menu-drawer__close-button path,
      .menu-drawer__close-button line {
        color: #1a1008 !important;
        stroke: #1a1008 !important;
        fill: none !important;
      }

      /* Navigation wrapper padding */
      .menu-drawer__navigation {
        padding-top: 60px !important;
        padding-left: 32px !important;
        padding-right: 32px !important;
      }

      /* Remove ALL dividers / borders from list items */
      .menu-drawer__menu li,
      .menu-drawer__list-item--flat,
      .menu-drawer__list-item--deep,
      .menu-drawer__list-item--divider {
        border: none !important;
        border-top: none !important;
        border-bottom: none !important;
        outline: none !important;
      }

      /* Main nav links — Cormorant Garamond, large, dark */
      .menu-drawer__menu-item--mainlist,
      a.menu-drawer__menu-item--mainlist,
      button.menu-drawer__menu-item--mainlist {
        font-family: 'Cormorant Garamond', Georgia, serif !important;
        font-size: 38px !important;
        font-weight: 400 !important;
        letter-spacing: 0.01em !important;
        text-transform: uppercase !important;
        color: #1a1008 !important;
        text-decoration: none !important;
        padding: 4px 0 !important;
        background: transparent !important;
        line-height: 1.2 !important;
        border: none !important;
        display: block !important;
      }

      /* Menu item text */
      .menu-drawer__menu-item-text,
      .menu-drawer__menu-item--mainlist span {
        font-family: 'Cormorant Garamond', Georgia, serif !important;
        font-size: 38px !important;
        font-weight: 400 !important;
        color: #1a1008 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.01em !important;
      }

      /* Active page */
      .menu-drawer__menu-item--active .menu-drawer__menu-item-text,
      [aria-current="page"].menu-drawer__menu-item--mainlist {
        color: #CD8F5C !important;
      }

      /* Hover */
      .menu-drawer__menu-item--mainlist:hover .menu-drawer__menu-item-text,
      a.menu-drawer__menu-item--mainlist:hover {
        color: #CD8F5C !important;
      }

      /* Hide extras */
      .menu-drawer__utility-links,
      .menu-drawer__localization,
      .menu-drawer__account {
        display: none !important;
      }

      /* TatianaGlen footer styles are owned by sections/tg-footer.liquid */
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }} template-{{ template.name }}" data-template="{{ template.name }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
