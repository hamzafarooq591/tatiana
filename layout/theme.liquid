<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    {%- comment -%} TatianaGlen: Hide ShopPay installments banner sitewide {%- endcomment -%}
    <style>
      .installments,
      shopify-payment-terms,
      .payment-terms,
      [class*="installment"],
      [id*="installment"] {
        display: none !important;
        visibility: hidden !important;
        height: 0 !important;
        overflow: hidden !important;
      }

      /* ============================================================
         TatianaGlen: Global nav — bold, spaced, uppercase
         ============================================================ */
      .menu-list__list {
        display: flex !important;
      }
      .menu-list__item a,
      .header-menu a,
      header-menu a,
      [class*="menu-list"] a {
        font-family: 'Open Sans', Arial, sans-serif !important;
        font-weight: 700 !important;
        letter-spacing: 0.1em !important;
        font-size: 0.82rem !important;
        text-transform: uppercase !important;
        text-decoration: none !important;
        transition: color 0.2s ease, border-color 0.2s ease !important;
      }

      /* ============================================================
         TatianaGlen: Homepage — transparent header overlay
         Force header-component to sit above the hero banner
         ============================================================ */
      body.template-index #header-group {
        position: relative;
        height: 0 !important;
        overflow: visible;
        z-index: 200;
      }

      body.template-index #MainContent {
        margin-top: 0 !important;
        padding-top: 0 !important;
      }

      /* Force the header element absolutely positioned over the hero */
      body.template-index header-component,
      body.template-index #header-component {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        z-index: 200 !important;
        background: transparent !important;
        background-color: transparent !important;
      }

      /* Wipe any scheme background classes on the header wrapper on index */
      body.template-index header-component .header,
      body.template-index header-component [class*="color-"] {
        background: transparent !important;
        background-color: transparent !important;
      }

      /* Nav link color: white on the transparent homepage header */
      body.template-index header-component .menu-list__item a,
      body.template-index header-component a[class*="menu"],
      body.template-index header-component nav a,
      body.template-index header-component .header__menu a {
        color: #ffffff !important;
      }

      /* Active / current page nav link: white + bottom underline */
      body.template-index header-component .menu-list__item--active > a,
      body.template-index header-component .menu-list__item[aria-current] > a,
      body.template-index header-component [aria-current="page"] {
        color: #ffffff !important;
        border-bottom: 2px solid #ffffff !important;
        padding-bottom: 2px !important;
      }

      /* Hover: TG amber */
      body.template-index header-component .menu-list__item a:hover,
      body.template-index header-component nav a:hover {
        color: #CD8F5C !important;
      }

      /* Header icons (account, search, cart) — white on transparent bg */
      body.template-index header-component .header__icon,
      body.template-index header-component .header-actions a,
      body.template-index header-component [class*="header-actions"] svg,
      body.template-index header-component button svg,
      body.template-index header-component a svg {
        color: #ffffff !important;
        fill: #ffffff !important;
        stroke: #ffffff !important;
      }

      /* ============================================================
         TatianaGlen footer styles are owned by sections/tg-footer.liquid
         ============================================================ */
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }} template-{{ template.name }}" data-template="{{ template.name }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
